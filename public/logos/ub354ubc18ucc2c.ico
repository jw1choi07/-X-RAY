<script>
	function resultView(imgCode) {
		var folder = "";
		var folderPath = "";

		if(imgCode != null) {
			var imgCodeLen = imgCode.length;

			if (imgCodeLen == 5 || imgCodeLen == 7) {
				folder = "model_img/main/";
				folderPath = imgCode.substr(0, 3);
			} else if(imgCodeLen == 6) {
				folder = "set_img/main/";
				folderPath = imgCode.substr(0, 4);
			} else if(imgCodeLen == 12){
				folder = "pick_img/main/";
				folderPath = imgCode.substr(0, 6);
			} else if(imgCodeLen == 9){
				folder = "product_img/main/";
				folderPath = imgCode.substr(0, 7);
			}
		}

		return folder + folderPath;
	}
</script>
<meta name="Title" content="더반찬&_동원몰" />
<meta name="Keywords" content="더반찬&,동원참치, 개성만두, 양반김, 양반김치, 양반죽, 무료배송, 합배송, 식품 쇼핑몰, 코스트코, 메가마트" />
<meta name="Description" content="더반찬& 입니다. :: 대형마트, 코스트코, 의약용품 등 1만여 종 상품을 한번에!  최대 90%할인 아울렛 특가 운영!" />

<!-- 카테고리 -->
<link rel="stylesheet" href="https://img.dongwonmall.com/dwmall/web/common/css/category.css?v=">
<!-- gnc 전문관 -->
<link rel="stylesheet" type="text/css" href="https://img.dongwonmall.com/dwmall/web/common/css/gnc.css?v="/>
<!-- 필터 -->
<link rel="stylesheet" href="https://img.dongwonmall.com/dwmall/web/common/css/filter.css?v=">

<!-- 수집 -->
<script>
    (function (window, document) {
        'use strict';

        if (window.DWTracker && window.DWTracker.__initialized) {
            return;
        }

        var DWTracker = {
            __initialized: false,

            config: {
                // DispatcherServlet이 *.do 요청만 처리하므로 서버 매핑에 도달하도록 .do URL을 사용한다.
                endpoint: '/common/ajax_tracker.do',
                debug: false,
                useBeacon: true,
                dedupeWindowMs: 250
            },

            eventMap: {
                banner: 'banner_click',
                carousel_control: 'carousel_control_click',
                tooltip: 'tooltip_click',
                product: 'product_click',
                open_new: 'open_new_click',
                cart: 'cart_click',
                wish: 'wish_click',
                buy_now: 'buy_now_click',
                gift: 'gift_click',
                category: 'category_click',
                filter: 'filter_click',
                sort: 'sort_click',
                view_type: 'view_type_click',
                page_move: 'page_move_click',
                option_select: 'option_select_click',
                quantity_change: 'quantity_change',
                search_submit: 'search_submit',
                link: 'link_click',
                sns: 'sns_click',
                dismiss: 'dismiss_click',
                tab: 'tab_click',
                review: 'review_click'
            },

            state: {
                lastKey: null,
                lastAt: 0
            },

            init: function (userConfig) {
                try {
                    this.config = this.extend(this.config, userConfig || {});
                    this.bindEvents();
                    this.__initialized = true;
                    // this.log('initialized', this.config);
                } catch (e) {
                    // 서비스 영향 없도록 무시
                }
            },

            bindEvents: function () {
                try {
                    document.addEventListener('click', this.handleClick.bind(this), true);
                    document.addEventListener('submit', this.handleSubmit.bind(this), true);
                    document.addEventListener('change', this.handleChange.bind(this), true);
                } catch (e) {
                    // noop
                }
            },

            handleClick: function (e) {
                try {
                    if (!e || !e.target) return;

                    var trigger = this.closest(e.target, '[data-action]');
                    if (!trigger) return;

                    var action = this.getAction(trigger);
                    if (!action) return;

                    // 검색은 submit에서 처리
                    if (action === 'search_submit') return;

                    var payload = this.buildPayload(trigger, null);
                    if (!payload) return;

                    this.send(payload);
                } catch (e) {
                    // noop
                }
            },

            handleSubmit: function (e) {
                try {
                    if (!e || !e.target) return;

                    var form = e.target;
                    if (!form || form.tagName.toLowerCase() !== 'form') return;

                    var trigger = form.querySelector('[data-action="search_submit"]');
                    if (!trigger) return;

                    var payload = this.buildPayload(trigger, form);
                    if (!payload) return;

                    this.send(payload);
                } catch (e) {
                    // noop
                }
            },

            handleChange: function (e) {
                try {
                    if (!e || !e.target) return;

                    var trigger = this.closest(e.target, '[data-action]');
                    if (!trigger) return;

                    var action = this.getAction(trigger);
                    if (!action) return;

                    if (
                        action !== 'filter' &&
                        action !== 'sort' &&
                        action !== 'view_type' &&
                        action !== 'option_select' &&
                        action !== 'quantity_change'
                    ) {
                        return;
                    }

                    var payload = this.buildPayload(trigger, null);
                    if (!payload) return;

                    this.send(payload);
                } catch (e) {
                    // noop
                }
            },

            buildPayload: function (trigger, formEl) {
                try {
                    var action = this.getAction(trigger);
                    var eventName = this.toEventName(action);

                    if (!action || !eventName) return null;

                    var pageContext = this.getPageContext();
                    var metadata = this.buildMetadata(trigger, formEl);

                    var payload = {
                        event_time: new Date().toISOString(),
                        page_type: pageContext.page_type,
                        section_id: this.getSectionId(trigger),
                        event_name: eventName,
                        component_id: this.getDataId(trigger),
                        device_id: this.getDeviceId(),
                        page_url: this.safe(function () {
                            return location.pathname + location.search;
                        }, null),
                        referrer_url: this.safe(function () {
                            return document.referrer || null;
                        }, null)
                    };

                    if (pageContext.special_mall) {
                        payload.special_mall = pageContext.special_mall;
                    }

                    if (pageContext.category_id) {
                        payload.category_id = pageContext.category_id;
                    }

                    if (metadata && this.hasKeys(metadata)) {
                        payload.metadata = metadata;
                    }

                    return payload;
                } catch (e) {
                    return null;
                }
            },

            buildMetadata: function (trigger, formEl) {
                var metadata = {};

                try {
                    var name = this.getNearestDataset(trigger, 'name') || this.attr(trigger, 'title');
                    var index = this.getNearestDataset(trigger, 'index');
                    var extra = this.getNearestDataset(trigger, 'extra');
                    var targetId = this.getNearestDataset(trigger, 'targetId');
                    var selectedIds = this.getNearestDataset(trigger, 'selectedIds');

                    if (name) metadata.component_name = name;
                    if (index) metadata.component_index = index;
                    if (extra) metadata.extra = extra;
                    if (targetId) metadata.target_id = targetId;

                    if (selectedIds) {
                        metadata.selected_ids = String(selectedIds).split(',').map(function (v) {
                            return v.trim();
                        }).filter(Boolean);
                    }

                    var action = this.getAction(trigger);
                    if (action === 'search_submit') {
                        var keyword = this.getSearchKeyword(trigger, formEl);
                        if (keyword) {
                            metadata.search_keyword = keyword;
                        }
                    }

                    return metadata;
                } catch (e) {
                    return {};
                }
            },

            getSearchKeyword: function (trigger, formEl) {
                try {
                    var form = formEl || this.closest(trigger, 'form');
                    if (!form) return null;

                    var input =
                        form.querySelector('input[name="searchTerm"]') ||
                        form.querySelector('input[type="search"]') ||
                        form.querySelector('input[type="text"]');

                    if (!input) return null;

                    return (input.value || '').trim() || null;
                } catch (e) {
                    return null;
                }
            },

            toEventName: function (action) {
                try {
                    return this.eventMap[action] || null;
                } catch (e) {
                    return null;
                }
            },

            getSectionId: function (el) {
                return this.getNearestDataset(el, 'sectionId') || 'unknown';
            },

            getAction: function (el) {
                return this.getNearestDataset(el, 'action') || null;
            },

            getDataId: function (el) {
                return this.getNearestDataset(el, 'id') || null;
            },

            getNearestDataset: function (el, datasetKey) {
                try {
                    var attrName = this.datasetKeyToAttr(datasetKey);
                    var found = this.closest(el, '[' + attrName + ']');
                    if (!found || !found.dataset) return null;
                    return found.dataset[datasetKey] || null;
                } catch (e) {
                    return null;
                }
            },

            datasetKeyToAttr: function (key) {
                try {
                    return 'data-' + key.replace(/([A-Z])/g, '-$1').toLowerCase();
                } catch (e) {
                    return '';
                }
            },

            getPageContext: function () {
                try {
                    var path = location.pathname || '';
                    var params = new URLSearchParams(location.search || '');

                    var pageType = 'other';
                    var specialMall = null;
                    var categoryId = null;

                    if (path === '/' || path === '/index.do') {
                        pageType = 'main';
                    } else if (path.indexOf('/category/special.do') > -1) {
                        pageType = 'category_special';
                        categoryId = params.get('cate_id');

                        if (categoryId === '01110050') specialMall = 'the_banchan';
                        if (categoryId === '01110018') specialMall = 'dongwon';
                    } else if (path.indexOf('/category/main.do') > -1) {
                        pageType = 'category_main';
                        categoryId = params.get('cate_id');
                    } else if (path.indexOf('/product/detail_deal.do') > -1) {
                        pageType = 'product_deal_detail';
                    } else if (path.indexOf('/product/detail.do') > -1) {
                        pageType = 'product_detail';
                    } else if (path.indexOf('/display/plan.do') > -1) {
                        pageType = 'promotion_detail';
                    } else if (path.indexOf('/display/dDayDeal.do') > -1) {
                        pageType = 'discount_day';
                    } else if (path.indexOf('/search/search.do') > -1 || path.indexOf('/search/') > -1) {
                        pageType = 'search';
                    } else if (path.indexOf('/gnc/main.do') > -1) {
                        pageType = 'brand_gnc';
                        specialMall = 'gnc';
                    } else if (path.indexOf('/chuchew/main.do') > -1) {
                        pageType = 'brand_chuchew';
                        specialMall = 'chuchew';
                    } else if (path.indexOf('/chatbot/chat.do') > -1) {
                        pageType = 'chatbot';
                    }

                    return {
                        page_type: pageType,
                        special_mall: specialMall,
                        category_id: categoryId
                    };
                } catch (e) {
                    return {
                        page_type: 'other',
                        special_mall: null,
                        category_id: null
                    };
                }
            },

            getDeviceId: function () {
                try {
                    return "DW_PC";
                } catch (e) {
                    return null;
                }
            },

            isDuplicate: function (payload) {
                try {
                    var key = [
                        payload.page_type,
                        payload.section_id,
                        payload.event_name,
                        payload.component_id
                    ].join('|');

                    var now = Date.now();

                    if (this.state.lastKey === key && (now - this.state.lastAt) < this.config.dedupeWindowMs) {
                        return true;
                    }

                    this.state.lastKey = key;
                    this.state.lastAt = now;
                    return false;
                } catch (e) {
                    return false;
                }
            },

            send: function (payload) {
                try {
                    if (!payload) return;
                    if (this.isDuplicate(payload)) return;

                    // this.log('send', payload);

                    var body = this.safe(function () {
                        // 트래킹 데이터가 공통 파라미터와 섞이지 않도록 서버에는 putData 아래 객체로만 전달한다.
                        return JSON.stringify({
                            putData: JSON.stringify(payload)
                        });
                    }, null);

                    if (!body) return;

                    if (this.config.useBeacon && navigator.sendBeacon) {
                        try {
                            var blob = new Blob([body], { type: 'application/json' });
                            var ok = navigator.sendBeacon(this.config.endpoint, blob);
                            if (ok) return;
                        } catch (e) {
                            // noop
                        }
                    }

                    try {
                        fetch(this.config.endpoint, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: body,
                            keepalive: true,
                            credentials: 'same-origin'
                        }).catch(function () {
                            // noop
                        });
                    } catch (e) {
                        // noop
                    }
                } catch (e) {
                    // noop
                }
            },

            closest: function (el, selector) {
                try {
                    if (!el || !selector || !el.closest) return null;
                    return el.closest(selector);
                } catch (e) {
                    return null;
                }
            },

            attr: function (el, name) {
                try {
                    return el && el.getAttribute ? el.getAttribute(name) : null;
                } catch (e) {
                    return null;
                }
            },

            hasKeys: function (obj) {
                try {
                    for (var k in obj) {
                        if (Object.prototype.hasOwnProperty.call(obj, k)) {
                            return true;
                        }
                    }
                    return false;
                } catch (e) {
                    return false;
                }
            },

            extend: function (base, extra) {
                try {
                    var out = {};
                    var k;

                    for (k in base) {
                        if (Object.prototype.hasOwnProperty.call(base, k)) {
                            out[k] = base[k];
                        }
                    }

                    for (k in extra) {
                        if (Object.prototype.hasOwnProperty.call(extra, k)) {
                            out[k] = extra[k];
                        }
                    }

                    return out;
                } catch (e) {
                    return base;
                }
            },

            safe: function (fn, fallback) {
                try {
                    return fn();
                } catch (e) {
                    return fallback;
                }
            },

            log: function () {
                if (!this.config.debug) return;
                try {
                    var args = Array.prototype.slice.call(arguments);
                    args.unshift('[DWTracker]');
                    console.log.apply(console, args);
                } catch (e) {
                    // noop
                }
            }
        };

        window.DWTracker = DWTracker;
    })(window, document);
</script>
<script type="text/javascript">
    (function () {
        try {
            if (!window.DWTracker || window.DWTracker.__initialized) return;

            window.DWTracker.init({
                // DispatcherServlet이 *.do 요청만 처리하므로 서버 매핑에 도달하도록 .do URL을 사용한다.
                endpoint: '/common/ajax_tracker.do',
                debug: true,
                useBeacon: true,
                dedupeWindowMs: 250
            });
        } catch (e) {
            // 서비스 영향 없도록 무시
        }
    })();
</script>
