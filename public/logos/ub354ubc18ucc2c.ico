//계열사 바로가기
$.fn.affiliate = function () {
	const affiliateBody = this;
	const affiliateBtn = affiliateBody.find('.js-affiliate');
	const affiliateList = affiliateBody.find('.affiliate-list');
	affiliateBtn.on('click', function (e) {
		e.preventDefault();
		if (affiliateBody.hasClass('opened')) {
		affiliateBody.removeClass('opened');
		affiliateList.stop().slideUp(200);
		} else {
		affiliateBody.addClass('opened');
		affiliateList.stop().slideDown(200);
		}
	});
	affiliateBtn.on('blur', function () {
		affiliateBody.removeClass('opened');
		setTimeout(function () {
		affiliateList.stop().slideUp(200);
		}, 100)
	});
}

	$(document).ready(function() {
		// 푸터 계열사 바로가기
		$('.footer .affiliate').affiliate();

		// 공지사항 리스트
		$.ajax({
			url: '/common/ajax_notice.do',
			type: 'GET',
			dataType: 'json',
			success: function (data) {
				var topNotice = data.topNotice;
				var BM_IDX = topNotice.BM_IDX;
				var BC_IDX = topNotice.BC_IDX;
				var B_IDX = topNotice.B_IDX;
				var B_TITLE = topNotice.B_TITLE;

				$('#FOOT_BM_IDX').val(BM_IDX);
				$('#FOOT_BC_IDX').val(BC_IDX);
				$('#FOOT_B_IDX').val(B_IDX);

				var innerHTML ='';
				innerHTML += "<a onclick='javascript:goNoticeList("+ BM_IDX +", "+ BC_IDX +", "+ B_IDX +", \"\");' class='lately-anc'>" + B_TITLE + "</a>";

				// 기존 a태그 삭제
				$('.lately-sbj.notice').find('a.lately-anc').remove();

				// 새 a태그 추가
				$('.lately-sbj.notice').append(innerHTML);
			}
		});

	});

	function goNoticeList(BM_IDX, BC_IDX, B_IDX, BC_SORT){
		$("#FOOT_BM_IDX").val(BM_IDX);
		$("#FOOT_BC_IDX").val(BC_IDX);
		$("#FOOT_B_IDX").val(B_IDX);
		$("#FOOT_BC_SORT").val(BC_SORT);
		$("#noticeFrm").attr({"target" : "_self", "action": "/customer/noticeList.do"}).submit();
	}
</script></div>
