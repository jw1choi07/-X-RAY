		<script type="text/javascript">
		//<![CDATA[
		//팝업 초기 설정
		function headerPopInit(){
		var hpopTotal = "0";

		

		if ( hpopTotal < 2 ){
		$(".header_popup").hide(0);
		headerPopOpen();
		}else{
		$(".header_popup .hpnum").text(hpopTotal);
		$(".header_popup").show(0);
		}
		}

		//팝업 사이즈 위치 설정
		function sizePosition_popup(p_seq, width, height, top, left){
		if(getCookie("dwpop"+p_seq) != "no"){
		var option = "width=" + width +", height=" + height + ", top=" + top + ", left=" + left + "toolbar=no,location=no,directory=no,status=no,menubar=no,scrollbars=no,resizable=no,copyhistory=no";
		window.open("/display/popup.do?p_seq="+p_seq, p_seq, option);
		}
		}

		//팝업 사이즈
		function size_popup(p_seq, width, height){
		if(getCookie("dwpop"+p_seq) != "no"){
		var option = "width=" + width +", height=" + height + "toolbar=no,location=no,directory=no,status=no,menubar=no,scrollbars=no,resizable=no,copyhistory=no";
		window.open("/display/popup.do?p_seq="+p_seq, p_seq, option);
		}
		}

		//팝업 사이즈 지정 안한 경우
		function no_size_popup(p_seq, top, left, getWidth, getHeight){
		if(getCookie("dwpop"+p_seq) != "no"){
		var option = "width=" + getWidth +", height=" + getHeight + "top=" + top +", left=" + left + "toolbar=no,location=no,directory=no,status=no,menubar=no,scrollbars=no,resizable=no,copyhistory=no";
		window.open("/display/popup.do?noSize=Y&p_seq="+p_seq, p_seq, option);
		}
		}

		//팝업 위치
		function position_popup(p_seq, top, left){
		if(getCookie("dwpop"+p_seq) != "no"){
		var option = "top=" + top + ", left=" + left + "toolbar=no,location=no,directory=no,status=no,menubar=no,scrollbars=no,resizable=no,copyhistory=no";
		window.open("/display/popup.do?p_seq="+p_seq, p_seq, option);
		}
		}

		//팝업 일반
		function nomal_popup(p_seq){
		if(getCookie("dwpop"+p_seq) != "no"){
		var option = "toolbar=no,location=no,directory=no,status=no,menubar=no,scrollbars=no,resizable=no,copyhistory=no";
		window.open("/display/popup.do?p_seq="+p_seq, p_seq, option);
		}
		}

