                    </div>
                </div>
                <div class="module-wrap">
                    <div class="component-filter">
                        <div class="filter-header on">
                            <strong class="filter-title">가격대</strong>
                            <span class="filter-toggle"></span>
                        </div>
                        <div class="filter-body">
                            <div class="price">
                                <div class="price-buttons">
                                    <a type="button" class="price-option" data-id="0" data-name="1만원 미만" data-min="0" data-max="9999" data-action="filter" data-id="1만원">1만원 미만</a>
                                    <a type="button" class="price-option" data-id="1" data-name="1만원~2만원" data-min="10000" data-max="19999" data-action="filter" data-id="1~2만원">1만원~2만원</a>
                                    <a type="button" class="price-option" data-id="2" data-name="2만원~3만원" data-min="20000" data-max="29999" data-action="filter" data-id="2~3만원">2만원~3만원</a>
                                    <a type="button" class="price-option" data-id="3" data-name="3만원~4만원" data-min="30000" data-max="39999" data-action="filter" data-id="3~4만원">3만원~4만원</a>
                                    <a type="button" class="price-option" data-id="4" data-name="4만원 이상" data-min="40000" data-max="99999999" data-action="filter" data-id="4만원" >4만원 이상</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <a href="#this" class="filter-btn" title="상품필터 접기"><span class="ir">필터 여닫기</span><span class="box"></span></a>
        </div>
    </form>
</div>

<script type="text/javascript">	
	function showAllCate() {
		$("#allCateList").show();
		$("#nowCateList").hide();
	}
	
    function goPage(currentPage,colTarget){
        $('#'+colTarget+'CurrentPage').val(currentPage);
        getSearchMore();
        var offset = $("#searchGoodsContentNew .search_prd_list").offset();
	    $('html, body').animate({scrollTop : offset.top - 300}, 300);
    }

    // 필터 초기화
    function initSearch(){
        $('#goodsCurrentPage').val(1);
        $(".selected-filter").empty();

        $('input:checkbox[name="specialSelect"]').prop("checked", false);
        $("#special").val("");

        $('input:checkbox[name="delTypeSelect"]').prop("checked", false);
        $('#delType').val("");

        $('input:checkbox[name="lcateSelect"]').prop("checked", false);

        // 밴드배송/임직원몰/전문관/카테고리의 경우 기존 카테 값을 유지하고 있어야 하기 때문
        var parent_id = $("#parent").val();
        if(!(parent_id == "band" || parent_id == "emp" || parent_id == "special" || parent_id == "category")) {
            $('#lcate').val("");
        }
        $('#mcate').val("");
        $('#scate').val("");

        $('input:checkbox[name="brandSelect"]').prop("checked", false);
        $('#brand').val("");

        $('input:checkbox[name="benefitsSelect"]').prop("checked", false);
        $('#benefits').val("");

        $(".price-option").removeClass("on");
        $('#sPrice').val("");
        $('#ePrice').val("");

        document.querySelectorAll(
            '.module-wrap .component-filter'
        )[0].style.display = 'none';

        getSearchMore();
    }

    function changeCategory(cateId,cateNM,flag){

        if('' === 'Y'){
            var offset = $("#searchGoodsContentNew").offset();
            var headerWrapFixed = $("#header_wrap").hasClass("fixed");
            
            if(headerWrapFixed) {
            	$('html, body').animate({scrollTop : offset.top - 100}, 300);	
            }else{
            	$('html, body').animate({scrollTop : offset.top - 250}, 300);
            }

            $("#content .mainTitle").text(cateNM);
        }

        //카테고리
        var back = flag;
        var html = "";

        if(cateId.length >= 16){//3뎁스
            $('b > span').each(function() {
                $(this).unwrap();
            });

            $('span').filter(function() {
                if($(this).text() == cateNM){
                    $(this).wrap('<b></b>');
                }
            });
        }else if(cateId.length >= 12 && cateId.length < 16){//2뎁스
            if(back == "Y"){
                cateId = cateId.substring(0,cateId.length-4);
            }
            $.ajax({
                type: "POST",
                url: "/search/searchCategory.do",
                data: {
                    searchCategory: cateId
                    ,searchTerm : ""
                },
                dataType: "json",
                async: !1,
                success: function (data) {
                    var list = data.categoryList;

                    if(back == "Y"){
                        $.each(data.categoryIds1, function (i, item) {
                            var cc_seq = item.split("_")[0];
                            var cc_nm = item.split("_")[1];
                            if(cateId == cc_seq){
                                cateNM = cc_nm;
                            }
                        });
                        $("#content .mainTitle").text(cateNM);
                    }

                    $(".component-filter.cate #nowCateList").empty();
                    //html += '<div class="filter-body" id="nowCateList">';
                    html += '   <div class="tree-group">';
                    html += '       <ul class="list-depth">';
                    html += '           <li class="list-item">';
                    if('' === 'Y' && back === "Y"){
                        html += '               <a href="javascript:showAllCate();" class="link link-back "><span class="txt">'+cateNM+'</span></a>';
                    }else{
                        html += '               <a href="javascript:changeCategory(\''+cateId+'\',\''+cateNM+'\',\'Y\');" class="link link-back "><span class="txt">'+cateNM+'</span></a>';
                    }
                    html += '               <ul class="list-depth">';
                    $.each(list, function (i, item) {
                        var cc_seq = item.split("_")[0];
                        var cc_nm = item.split("_")[1];
                        var cc_cnt = item.split("_")[2];
                        html += '                   <li class="list-item">';
                        html += '                       <a href="javascript:changeCategory(\''+cc_seq+'\',\''+cc_nm+'\',\'N\');" class="link">';
                        html += '                           <span>'+cc_nm+'</span>';
                        //html += '                           <span class="num">'+setComma(cc_cnt)+'</span>';
                        html += '                       </a>';
                        html += '                   </li>';
                    });
                    html += '               </ul>';
                    html += '           </li>';
                    html += '       </ul>';
                    if(list.length > 5) {
                        html += '<button type="button" class="button-more" title="더보기"><span class="text">더보기</span></button>';
                    }
                    html += '   </div>';
                    //html += '</div>';
                    $(".component-filter.cate #nowCateList").append(html);         
                    
                    morethan(); // 카테고리 필터 항목 5개 초과 시 숨김
                }
            });
        }else if(cateId.length >= 8 && cateId.length < 12){//1뎁스
            if(back == "Y"){
                cateId = cateId.substring(0,cateId.length-4);
            }
            $.ajax({
                type: "POST",
                url: "/search/searchCategory.do",
                data: {
                    searchCategory: cateId
                    ,searchTerm : ""
                },
                dataType: "json",
                async: !1,
                success: function (data) {
                    var list = data.categoryList;
                    // console.log("1depth categoryList : " + list);

                    $(".component-filter.cate #nowCateList").empty();
                    if(back == "Y"){
                        // html += '<div class="filter-header on">';
                        // html += '   <strong class="filter-title">카테고리</strong>';
                        // html += '   <span class="filter-toggle"></span>';
                        // html += '</div>';
                        //html += '<div class="filter-body" id="nowCateList">';
                        html += '   <div class="tree-group">';
                        html += '       <ul class="list-depth">';
                        $.each(list, function (i, item) {
                            var cc_seq = item.split("_")[0];
                            var cc_nm = item.split("_")[1];
                            var cc_cnt = item.split("_")[2];
                            html += '                   <li class="list-item">';
                            html += '                       <a href="javascript:changeCategory(\''+cc_seq+'\',\''+cc_nm+'\',\'N\');" class="link">';
                            html += '                           <span class="txt">'+cc_nm+'</span>';
                            //html += '                           <span class="num">'+setComma(cc_cnt)+'</span>';
                            html += '                       </a>';
                            html += '                   </li>';
                        });
                        html += '       </ul>';
                        if(list.length > 5) {
                            html += '<button type="button" class="button-more" title="더보기"><span class="text">더보기</span></button>';
                        }
                        html += '   </div>';
                        //html += '</div>';
                    }else{
                        //html += '<div class="filter-body" id="nowCateList">';
                        html += '   <div class="tree-group">';
                        html += '       <ul class="list-depth">';
                        html += '           <li class="list-item">'; //onclick="removeCheckItem('+$(obj).attr("data-pbcode")+')"
                        html += '               <a href="javascript:changeCategory(\''+cateId+'\',\''+cateNM+'\',\'Y\');" class="link link-back "><span class="txt">'+cateNM+'</span></a>';
                        html += '               <ul class="list-depth">';
                        $.each(list, function (i, item) {
                            var cc_seq = item.split("_")[0];
                            var cc_nm = item.split("_")[1];
                            var cc_cnt = item.split("_")[2];
                            html += '                   <li class="list-item">';
                            html += '                       <a href="javascript:changeCategory(\''+cc_seq+'\',\''+cc_nm+'\',\'N\');" class="link">';
                            html += '                           <span>'+cc_nm+'</span>';
                            //html += '                           <span class="num">'+setComma(cc_cnt)+'</span>';
                            html += '                       </a>';
                            html += '                   </li>';
                        });
                        html += '               </ul>';
                        html += '           </li>';
                        html += '       </ul>';
                        if(list.length > 5) {
                            html += '<button type="button" class="button-more" title="더보기"><span class="text">더보기</span></button>';
                        }
                        html += '   </div>';
                        //html += '</div>';
                    }
                    $(".component-filter.cate #nowCateList").append(html);
                    
                    morethan(); // 카테고리 필터 항목 5개 초과 시 숨김
                }
            });
        }

        //값 세팅
        $("#lcate").val(cateId);

        //상품리스트 load
        getSearchMore();

    }

    function changeFilter(){

        var lcate = "";
        var special = ""; //전문관
        var delType = ""; //배송유형
        var benefits = ""; //혜택
        var brand = ""; //브랜드
        var sPrice = 9999999; //최소금액
        var ePrice = 0; //최대금액

        //카테고리 - changeCategory에서

        //전문관 (사실상 카테고리 코드로 구분하기 때문에 카테고리에 덧대어지면 됨)
        $('input:checkbox[name="specialSelect"]').each(function() {
            if(this.checked){
                if(this.value == "01110040"){//GNC는 브랜드로 검색됨
                    brand += "15_GNC" + "$|";
                }else{
                    special += this.value + "$|";
                }
            }
        });
        $("#special").val(special);

        //배송유형
        $('input:checkbox[name="delTypeSelect"]').each(function() {
            if(this.checked){
                delType += this.value + "$|";
            }
        });
        delType = delType.substring(0,delType.length-2);
        $('#delType').val(delType);

        //혜택
        $('input:checkbox[name="benefitsSelect"]').each(function() {
            if(this.checked){
                benefits += this.value + "$|";
            }
        });
        $('#benefits').val(benefits);

        //브랜드
        $('input:checkbox[name="brandSelect"]').each(function() {
            if(this.checked){
                brand += this.value + "$|";
            }
        });
        $('#brand').val(brand);

        //가격대
        if($(".price-option.on").size() > 0){//선택된게 있거나,  입력칸에 값이 있을 때
            $(".price-option.on").each(function() {
                if(sPrice >= parseInt($(this).attr("data-min"))){
                    sPrice = parseInt($(this).attr("data-min"));
                }
                if(ePrice <= parseInt($(this).attr("data-max"))){
                    ePrice = parseInt($(this).attr("data-max"));
                }
            });
            $("#sPrice").val(sPrice);
            $("#ePrice").val(ePrice);
        }else{
            $("#sPrice").val("");
            $("#ePrice").val("");
        }

        getSearchMore('Y');
        
        var offset = $("#searchGoodsContentNew").offset();
        var headerWrapFixed = $("#header_wrap").hasClass("fixed");
        
        if(headerWrapFixed) {
        	$('html, body').animate({scrollTop : offset.top - 100}, 300);	
        }else{
        	$('html, body').animate({scrollTop : offset.top - 250}, 300);
        }
        
    }

    function getSearchMore(goPrYn){
        var url = "/search/searchGoodsContentNew2.do";
        url += "?colTarget="+$('#colTarget').val();
        url += "&goodsCurrentPage="+$('#goodsCurrentPage').val();
        url += "&exhibitionCurrentPage="+$('#exhibitionCurrentPage').val();
        url += "&recipeCurrentPage="+$('#recipeCurrentPage').val();
        url += "&orderBy="+$('#orderBy').val();
        url += "&rowsperPage="+$('#rowsperPage').val();
        url += "&lcate="+encodeURIComponent($('#lcate').val());
        url += "&brand="+encodeURIComponent($('#brand').val());
        url += "&special="+encodeURIComponent($('#special').val());
        url += "&sPrice="+$('#sPrice').val();
        url += "&ePrice="+$('#ePrice').val();
        url += "&oldSearchTerm="+encodeURIComponent($('#oldSearchTerm').val());
        url += "&sPriceG="+$('#sPriceG').val();
        url += "&ePriceG="+$('#ePriceG').val();
        url += "&priceChange="+$('#priceChange').val();
        url += "&reSearch="+$('#reSearch').val();
        url += "&searchTerm="+encodeURIComponent($('#searchTerm').val());
        url += "&productListImg="+$('#productListImg').val();
        url += "&delType=" + encodeURIComponent($('#delType').val());
        url += "&benefits=" + encodeURIComponent($('#benefits').val());
        url += "&bandMart="+$('#bandMart').val();
        url += "&searchType="+encodeURIComponent($('#searchTab').val());

        // 밴드배송, 임직원몰내 검색시
        if($("#searchTab").val() == "band"){
            url += "&bandSearch=Y&bandCate_id=01120008";
        }else if($("#searchTab").val() == "emp"){
            url += "&bandSearch=Y&bandCate_id=01120011";
        }

        // parent 값 비어있는 경우 검색결과, 그 외에는 밴드배송/임직원몰/전문관/카테고리 임을 구분하기 위함
        var parent_id = $("#parent").val();
        if(parent_id == "band" || parent_id == "emp" || parent_id == "special" || parent_id == "category") {
            url += "&parent="+encodeURIComponent(parent_id);
        }
        
     	// 상품목록 노출 타입
    	var $prListSelected = $('.view-icons a.on');
    	if ($prListSelected.hasClass('grid-view')) {
    		url += "&prListType=grid";
    	} else if ($prListSelected.hasClass('list-view')) {
    		url += "&prListType=list";
    	}
        
        if ($('#colTarget').val() == "recipe"){
            $('#searchForm').submit();
        } else {
            $.ajax({
                type: "GET",
                url: url,
                success: function(data){
                    $('#searchGoodsContentNew').html(data);
                    lazyloadFunc();

                    if(goPrYn == "Y" && $("#totalCount").val() == 0){
                        $('#searchGoodsContentNew').empty();
                        var noPrHtml = "<div class='no-data'><p>조건에 맞는 상품이 없습니다</p><a href='javascript:initSearch();' class='btn-reset-filter'><span>필터 초기화</span></a></div>";
                        $("#searchGoodsContentNew").append(noPrHtml);
                    }
                  
					setTimeout(() => {
					  updateHeights(); // 높이값 갱신
					  onScroll(); // 현재 스크롤 위치에 맞게 갱신
					}, 50); // DOM 업데이트 반영 시간
				
					// 탭 클릭 시 갱신된 D-DAY딜 데이터에 맞춰 Swiper 재초기화
					initDealSwiper();
                  
                }
            });
        }

        // 검색 옵션 보이는 영역 관리
        //setSearchOptionArea();
    }

    function showImgType(){
        // <추천상품영역 추가를 위함>
        var isFilterOn = $('.content-filters').hasClass('on');
        if(isFilterOn){
            $('#iconSortType').val("three");
            $('#related-pr-recommend').remove();
        }else {
            $('#iconSortType').val("four");
            $('#related-pr-recommend').remove();
        }
        // </추천상품영역 추가를 위함>

        $("#productlist_img").css("display", "");
        $("#productlist").css("display", "none");

        $("#productListImg").val("img");
        $(".grid-view").addClass("on");
        $(".list-view").removeClass("on");
        // $("#productlist").removeClass("productlisttype1");
        // $("#productlist").addClass("productimgtype4");
        $(".itype_dongwonsum").hide();
        $(".itype_dongwonfreeze").hide();
        proImgType(".productimgtype4", 4);
    }

    function showListType(){
        $('#iconSortType').val("one");  // 추천상품영역 추가를 위함
        $('#related-pr-recommend').remove();

        $("#productlist_img").css("display", "none");
        $("#productlist").css("display", "");

        $("#productListImg").val("list");
        $(".grid-view").removeClass("on");
        $(".list-view").addClass("on");
        // $("#productlist").removeClass("productimgtype4");
        // $("#productlist").addClass("productlisttype1");
        $(".itype_dongwonsum").show();
        $(".itype_dongwonfreeze").show();
        proListType(".productlisttype1");
    }
</script><!-- 상품 목록 -->
<div id="searchGoodsContentNew" class="content-products shrink"></div>
</section>
