    /*
    * 장바구니 담기 & 찜하기 Start
    * */
    
    $(".btn_quick").click(function (e) {
        if ($(e.target).parent().hasClass("cart")) {
            // 전문관 > 2. 전문관 카테고리 내 상품 장바구니 담기
            var set_yn = $(e.target).parent().parent().parent().attr('data-item-comcd') == '02' ? 'Y' : 'N';
            // 장바구니 담기
            airbridgeScript.addToCart($(e.target).parent().parent().parent().attr('data-item-id'),
                $(e.target).parent().parent().parent().attr('data-item-name'),
                $(e.target).parent().parent().parent().attr('data-item-price'),
                $(e.target).parent().parent().parent().attr('data-item-brand'), 1,
                $(e.target).parent().parent().parent().attr('data-item-category1'),
                $(e.target).parent().parent().parent().attr('data-item-category3'), set_yn);
        }
    });
    $(".btn_cart").click(function (e) {
        // 전문관 > 2. 전문관 카테고리 내 상품 장바구니 담기
        var set_yn = $(e.target).attr('data-item-comcd') == '02' ? 'Y' : 'N';
        // 장바구니 담기
        airbridgeScript.addToCart($(e.target).attr('data-item-id'),
            $(e.target).attr('data-item-name'),
            $(e.target).attr('data-item-price'),
            $(e.target).attr('data-item-brand'), 1,
            $(e.target).attr('data-item-category1'),
            $(e.target).attr('data-item-category3'), set_yn);
    });
    $(".btn_like").click(function (e) {
        // 찜하기
        // 전문관 > 2. 전문관 카테고리 내 상품
        var set_yn = $(e.target).parent().children('.btn_cart').attr('data-item-comcd') == '02' ? 'Y' : 'N';
        // 찜하기
        airbridgeScript.addToWish($(e.target).parent().children('.btn_cart').attr('data-item-id'),
            $(e.target).parent().children('.btn_cart').attr('data-item-name'),
            $(e.target).parent().children('.btn_cart').attr('data-item-price'),
            $(e.target).parent().children('.btn_cart').attr('data-item-category1'),
            $(e.target).parent().children('.btn_cart').attr('data-item-category3'), set_yn);
    });
    
