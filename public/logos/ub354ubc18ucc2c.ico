			<script>
					(function () {
						if (window.__DD_RUM_LOADED__) return;
						window.__DD_RUM_LOADED__ = true;

                        const IS_BOT = /(googlebot|adsbot|mediapartners-google|storebot-google|google-site-verification|bingbot|bingpreview|msnbot|adidxbot|duckduckbot|baiduspider|yandexbot|slurp|yeti|naverbot|applebot|facebookexternalhit|facebookcatalog|twitterbot|linkedinbot|pinterest|whatsapp|semrushbot|ahrefsbot|mj12bot|dotbot|rogerbot|screaming frog|headlesschrome|phantomjs|selenium|crawl)/i.test(navigator.userAgent || '');

                        const shouldFilterEvent = (event) => {
                            try {
								// blob URL URI malformed 에러 및 MetaMask 확장 프로그램 에러 제외
								if (event.type === 'error') {
									const errMsg = event.error?.message || '';
									const errStack = event.error?.stack || '';

									if ((errMsg.indexOf('URI malformed') !== -1 && errStack.indexOf('blob:') !== -1) ||
											errMsg.indexOf('MetaMask') !== -1) {
										return true;
									}
								}

                                // 필터링할 키워드 목록
                                const filterKeywords = [
                                    '_la',
                                    'airbridge',
                                    'sauceflex.com',
                                    'nsm-corp.com',
                                    'enp_tracker',
                                    'megadata.co.kr',
                                    'megadata',
                                    'braze',
                                    'criteo',
                                    'taboola',
                                    'appboycdn',
                                    'googletagmanager',
                                    'google-analytics',
                                    'facebook.net',
                                    'connect.facebook',
                                    'analytics.js',
                                    'gtm.js'
                                ];

                                try {
                                    const eventStr = JSON.stringify(event).toLowerCase();
                                    for (const keyword of filterKeywords) {
                                        if (eventStr.includes(keyword.toLowerCase())) {
                                            return true;
                                        }
                                    }
                                } catch (e) {
                                    // JSON.stringify 실패시 개별 속성 체크로 진행
                                }

                                if (event.type === 'error') {
                                    const errorMessage = event.error?.message || '';
                                    const errorStack = event.error?.stack || '';
                                    const errorSource = event.error?.source || '';
                                    const errorType = event.error?.type || '';
                                    const handlingStack = event.error?.handling_stack || '';
                                    const errorUrl = event.view?.url || '';

                                    const combined = (errorMessage + errorStack + errorSource + errorType + handlingStack + errorUrl).toLowerCase();

                                    for (const keyword of filterKeywords) {
                                        if (combined.includes(keyword.toLowerCase())) {
                                            return true;
                                        }
                                    }
                                }

                                if (event.type === 'resource') {
                                    const resource = event.resource;
                                    if (resource) {
                                        const resourceUrl = (resource.url || '').toLowerCase();
                                        for (const keyword of filterKeywords) {
                                            if (resourceUrl.includes(keyword.toLowerCase())) {
                                                return true;
                                            }
                                        }
                                    }
                                }

                                if (event.context) {
                                    try {
                                        const contextStr = JSON.stringify(event.context).toLowerCase();
                                        for (const keyword of filterKeywords) {
                                            if (contextStr.includes(keyword.toLowerCase())) {
                                                return true;
                                            }
                                        }
                                    } catch (e) {
                                        // do nothing
                                    }
                                }

                                if (event.view?.url) {
                                    const viewUrl = event.view.url.toLowerCase();
                                    for (const keyword of filterKeywords) {
                                        if (viewUrl.includes(keyword.toLowerCase())) {
                                            return true;
                                        }
                                    }
                                }

                            } catch (e) {
                                console.error('shouldFilterEvent error:', e);
                                return false;
                            }
                            return false;
                        };

						if (IS_BOT) { console.debug('RUM disabled for crawler'); }
						else {
							(function(h,o,u,n,d) {
								h=h[d]=h[d]||{q:[],onReady:function(c){h.q.push(c)}}
								d=o.createElement(u);d.async=1;d.src=n
								n=o.getElementsByTagName(u)[0];n.parentNode.insertBefore(d,n)
							})(window,document,'script','https://www.datadoghq-browser-agent.com/us1/v6/datadog-rum.js','DD_RUM')
							window.DD_RUM.onReady(function() {
								window.DD_RUM.setUserProperty('id', '');
								window.DD_RUM.setUserProperty('name', 'public_user');

								window.DD_RUM.init({
									clientToken: 'pubf79048d96ab10817e35860d9fe6d4f15',
									applicationId: 'b292fe2c-119e-4548-a330-71c6ad10ced0',
									// `site` refers to the Datadog site parameter of your organization
									// see https://docs.datadoghq.com/getting_started/site/
									site: 'datadoghq.com',
									service: 'dwm-pc',
									env: 'prod',
									// Specify a version number to identify the deployed version of your application in Datadog
									version: '1.0.0',
									allowedTracingUrls: ["https://www.dongwonmall.com", (url) => url.startsWith("https://www.dongwonmall.com")],
									sessionSampleRate: 30,
									sessionReplaySampleRate: 100,
									defaultPrivacyLevel: 'mask-user-input',
                                    beforeSend: (event, context) => {
                                        if (event.type === 'view') return true;
                                        if (shouldFilterEvent(event)) return false;
                                        return true;
                                    },
									forwardConsoleLogs : 'all',
								});
							});
						}
					})();
				</script>
