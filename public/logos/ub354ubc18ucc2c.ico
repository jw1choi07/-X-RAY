<script>	
	function changeOrderBy(orderBy) {
		$('#orderBy').val(orderBy);
		$('#goodsCurrentPage').val(1);
		$('#exhibitionCurrentPage').val(1);
		$('#recipeCurrentPage').val(1);
		getSearchMore();
	}
	
	function changeRowsperPage() {
		$('#rowsperPage').val($('#rowsperPageSelect').val());
		$('#goodsCurrentPage').val(1);
		getSearchMore();
	}

	//찜 하기 기능
	function fnWishProc(id,pbCode) {
		checkLogin().done(function(data) {
			if (data.rst) {
				$.ajax({
					type : "POST",
					url : "/display/productWishProc.do",
					data : {
						PB_CODE : pbCode
					},
					dataType : "json",
					async : !1,
					success : function(data) {
						if(data.procGbn == "insert") {
							$(id).addClass("liked");
						} else {
							$(id).removeClass("liked");
						}
						alert(data.messages);
					},
					error : function(e) {
						alert("에러가 발생하였습니다.");
					}
				});
			} else {
				if (confirm("로그인이 필요합니다.\n로그인하시겠습니까?")) {
					goLogin();
				}else{
					$(id).removeClass("liked");
					return false;
				}
			}
		});
	}

	//레코픽 리스트 장바구니 담기 실행 시
	function prAddCart(pbCode){
		addCart(this,'',pbCode,'');
	}
</script>
