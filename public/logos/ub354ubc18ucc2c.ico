<div id="wrap">
    <script>
		  $(document).ready(function () {
				if (document.getElementById("top-banner-cont")) {
					  $('.top-banner').show();
					  cookiedata = document.cookie;
					  if ( cookiedata.indexOf("top-banner-cont=done") < 0 ){ //쿠키 변경 여부 불러오기
					  	document.getElementById('top-banner-cont').style.visibility = "visible";
					  }
					  else {
					  	document.getElementById('top-banner-cont').style.display = "none";
					  	$('#top-banner-wrap').remove();
					  }
					}
				});

				function PopupNoDisplay_1() {
				  setCookie("top-banner-cont", "done", 1); //쿠키값 변경
				  PopupHide();
				  $('.mall_box').addClass('topfix');
				}

				function PopupHide() { //팝업창 지우기
				  $('#top-banner-wrap').remove();
				  $("main").addClass('tb-hide');
				  $('.main-header').addClass('tb-hide');
				  $('main').removeClass('tb-show');
				  $('.monthly .cate-top-menu').removeClass('fixed-tb');
				  $('.monthly .cate-top-menu').addClass('fixed-normal');
				}
		</script>
