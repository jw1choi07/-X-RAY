		<!-- 구글 Analytics4 script -->
		<!-- 개발, 운영 모두 진행 -->
		<script type="text/javascript">
	
	// console.log("commandMap.DW_REQUEST_URI :::"+"/category/special.do");
	// console.log("commandMap.REQ_URI ::: "+"/category/special.do");

	function ajaxAwsKinesisRecord(putData) {
		if(putData != undefined) {
			var datas = new Array();
			putData.forEach(function (data) {
				try {
					var event = data.event;
					delete data['gtm.uniqueEventId'];
					if(event.indexOf('gtm.') > -1) {
						// if(event == 'gtm.js') {
						// 	datas.push(data);
						// }
						// if(event == 'gtm.click' && data['gtm.elementUrl'] != '') {
						// 	datas.push(data);
						// }
					} else {
						// 이전페이지
						data.referrer = document.referrer;
						datas.push(data);
					}
				} catch(e) {}
			});

			//datas.push({'referrer' : document.referrer});

			$.ajax({
				type: "POST", url : '/common/ajax_awsKinesis.do',
				data : {'putData' : JSON.stringify(datas)},
				success : function(){
					// console.log("success");
				},
				error: function(xhr, status, error) {
					console.error("ajax error", {
						url: this.url,
						status: xhr.status
					});
				}
			});
		}
	}

	$('html').click(function(e){
		//메뉴 및 공통영역 > 1. 메뉴 클릭 
		if($(e.target).hasClass('depth1') || $(e.target).parent().parent().parent().hasClass('depth2') || $(e.target).parent().parent().parent().hasClass('depth3')){
		    dataLayer.push({
		 		'event': 'click_menu',
		 		'menu' : $(e.target).text()
		    });
			// ajaxAwsKinesisRecord(dataLayer);
		}
		
		//메뉴 및 공통 작업 - 오늘의 추천상품선택
		/* if($(e.target).hasClass('thumb') || $(e.target).hasClass('info') || $(e.target).parent().hasClass('info')){
			
			dataLayer.push({
				'event': 'select_item',
				'item_list_id' : 'main',
				'item_list_name' : '메인 - 한 분만을 위한 오늘의 추천!',
			  	'ecommerce': {
					'items': [
					    {
					      'item_id': $(e.target).parent().attr('data-code'),
					      'item_name': $(e.target).parent().find('.info p').text(),
					      'price': $(e.target).parent().attr('data-value')
					    }
					  ]
			  	}
			});	
		} */
	});
</script>

<script type="text/javascript">
		window.dataLayer = window.dataLayer || [];
		
		$('.pic').click(function(e){
			// 전문관 > 1. 전문관 카테고리 내 베스트 상품 클릭 
			if($(e.target).hasClass('pic') && !($(e.target).parents().hasClass('cart'))){	
				dataLayer.push({
	    			'event': 'select_item',
	    			'item_list_id' : 'special',
	    			'item_list_name' : '전문관 - ' + $('meta[name="Title"]' ).attr('content'),
	    		    'ecommerce': {
	    				'items': [
	    				    {
	    				      'item_id':  $(e.target).parent().parent().attr('data-item-id'),
	    				      'item_name': $(e.target).parent().parent().attr('data-item-name'),
	   						  'price': $(e.target).parent().parent().attr('data-item-price')
	    				    }
	    				]
	    		    }
	    		});
				ajaxAwsKinesisRecord(dataLayer);
			};
			
	    });
		
		$(".btn_quick").click(function(e) {
			if($(e.target).parent().hasClass("cart")) {
				// 전문관 > 2. 전문관 카테고리 내 상품 장바구니 담기
	    		dataLayer.push({
	    			'event': 'add_to_cart',
	    			'item_list_id' : 'special',
	    			'item_list_name' : '전문관 - ' + $('meta[name="Title"]' ).attr('content'),
	    		    'ecommerce': {
	    				'items': [
	    				    {
	    				      'item_id':  $(e.target).parent().parent().parent().attr('data-item-id'),
	    				      'item_name': $(e.target).parent().parent().parent().attr('data-item-name'),
	   						  'price': $(e.target).parent().parent().parent().attr('data-item-price')
	    				    }
	    				]
	    		    }
	    		});
				ajaxAwsKinesisRecord(dataLayer);
			}
		});

		//전문관 > 3. 슬라이드 배너 클릭
		$('.band_top_slide').find('a').click(function(e) {
			dataLayer.push({
				'event': 'click_special_slider',
				'no': $(e.target).parent().parent().parent().attr('data-swiper-slide-index'),
				'title': $(e.target).parent().parent().attr('title'),
				'click_url': $(e.target).parent().parent().attr('href')
			});
			ajaxAwsKinesisRecord(dataLayer);

		});
	</script>	
<!-- AirBridge script -->
		<!-- 개발, 운영 모두 진행 -->
		<script type="text/javascript">

    var airbridgeScript = {
        addToCart: function (pbCode, pbNm, price, brand, prCnt, ca1, ca2, set) {
            airbridge.events.send('airbridge.ecommerce.product.addedToCart', {
                label: pbNm,
                action: brand,
                value: price * prCnt, // 장바구니 담은 상품 가격
                semanticAttributes: {
                    products: [
                        {
                            productID: pbCode,
                            name: pbNm,
                            price: price,
                            currency: 'KRW',
                            quantity: prCnt,
                            position: 1
                        }
                    ],
                    quantity: 3,
                    currency: 'KRW'
                },
                customAttributes: {
                    products: [
                        {
                            category1: ca1,
                            category2: ca2,
                            setYn: set,
                            position: 1
                        }
                    ]
                }
            });
        },
        addToWish: function (pbCode, pbNm, price, ca1, ca2, set) {
            airbridge.events.send('airbridge.addToWishlist', {
                label: pbCode,
                action: ca1,
                value: price, // 상품 금액
                semanticAttributes: {
                    products: [
                        {
                            productID: pbCode,
                            name: pbNm,
                            price: price,
                            currency: 'KRW',
                            position: 1
                        }
                    ],
                    currency: 'KRW'
                },
                customAttributes: {
                    products: [
                        {
                            category1: ca1,
                            category2: ca2,
                            setYn: set,
                            position: 1
                        }
                    ]
                }
            });
        },
        addToGift: function (pbCode, pbNm, price, brand, prCnt, ca1, ca2, set) {
            // 선물하기 담기
            airbridge.events.send("add_to_gift", {
                label: pbNm,
                action: ca1,
                value: price * prCnt, // 장바구니 담은 상품 가격
                semanticAttributes: {
                    products: [
                        {
                            productID: pbCode,
                            name: pbNm,
                            price: price,
                            currency: 'KRW',
                            quantity: prCnt,
                            position: 1
                        }
                    ],
                    quantity: prCnt,
                    currency: 'KRW'
                },
                customAttributes: {
                    products: [
                        {
                            category1: ca1,
                            category2: ca2,
                            setYn: set,
                            position: 1
                        }
                    ]
                }
            });
        },
        orderProduct: function (pbCode, pbNm, price, brand, prCnt, ca1, ca2, set, tid) {
            // 상품별 구매
            airbridge.events.send('order_product', {
                label: pbNm,
                action: ca1,
                value: price * prCnt, // 상품가격
                semanticAttributes: {
                    products: [
                        {
                            productID: pbCode,
                            name: pbNm,
                            price: price,
                            currency: 'KRW',
                            quantity: prCnt,
                            position: 1
                        }
                    ],
                    currency: 'KRW',
                    quantity: prCnt,
                    transactionID: tid
                },
                customAttributes: {
                    products: [
                        {
                            category1: ca1,
                            category2: ca2,
                            setYn: set,
                            position: 1
                        }
                    ]
                }
            });
        },
        share: function (p_path, s_path) {
            // 공유
            airbridge.events.send('airbridge.share', {
                customAttributes: {
                    page_path: p_path,
                    share_path: s_path,
                }
            });
        },
        viewReview: function (pbCode, pbNm, price, ca1, ca2, set) {
            // 리뷰 확인
            airbridge.events.send("view_review", {
                label: pbNm,
                action: ca1,
                value: 0, // 상품 가격
                semanticAttributes: {
                    products: [
                        {
                            productID: pbCode,
                            name: pbNm,
                            price: price,
                            currency: 'KRW',
                            quantity: 1,
                            position: 1
                        }
                    ],
                    currency: 'KRW'
                },
                customAttributes: {
                    products: [
                        {
                            category1: ca1,
                            category2: ca2,
                            setYn: set,
                            position: 1
                        }
                    ]
                }
            });
        },
        unlockAchievement: function (val) {
            // 출석체크
            airbridge.events.send('airbridge.unlockAchievement', {
                value: val, // 적립 포인트
            });
        },
        rate: function () {
            // 평가
            airbridge.events.send("airbridge.rate");
        },
        deleteToCart: function (pbCode, pbNm, prCnt, price, ca1, ca2, set) {
            // 장바구니 취소
            airbridge.events.send("delete_to_cart", {
                label: pbNm,
                action: ca1,
                value: price, // 장바구니 담은 상품 가격
                semanticAttributes: {
                    products: [
                        {
                            productID: pbCode,
                            name: pbNm,
                            price: price,
                            currency: 'KRW',
                            quantity: prCnt,
                            position: 1
                        }
                    ],
                    currency: 'KRW'
                },
                customAttributes: {
                    products: [
                        {
                            category1: ca1,
                            category2: ca2,
                            setYn: set,
                            position: 1
                        }
                    ]
                }
            });
        },
        orderCanceled: function (tid, grdTxt, totalPrice, products, products2) {
            // 구매취소
            airbridge.events.send('airbridge.ecommerce.order.canceled', {
                label: grdTxt,
                value: totalPrice, // 취소 금액
                semanticAttributes: {
                    products: products,
                    currency: 'KRW',
                    transactionID: tid
                },
                customAttributes: {
                    grade: grdTxt,
                    products: products2
                }
            });
        },
    }

    // console.log("commandMap.DW_REQUEST_URI :::" + "/category/special.do");
    // console.log("commandMap.REQ_URI ::: " + "/category/special.do");

    // Testing the SDK
    // console.log('airbridge.isSDKEnabled: ' + window.airbridge.isSDKEnabled);

    /*
