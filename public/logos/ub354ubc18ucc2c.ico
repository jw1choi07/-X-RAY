            <span class="option-name"></span>
            <div class="option-quantity">
              <div class="qty-box">
                <div class="quantity-controls">
                  <button onclick="changeQuantity(2, -1)">-</button>
                  <input type="number" id="quantity-2" value="1" readonly>
                  <button onclick="changeQuantity(2, 1)">+</button>
                </div>
              </div>
              <div class="price">8,000원</div>
              <button onclick="removeOption(2)" class="close-btn">
                <i class="icon icon-close"></i>
              </button>
            </div>
          </div>
        </div>
        <div class="total-price">
          <small>총</small><span class="price"><strong>20,610</strong>원</span>
        </div>
      </div>
    </div>
    <div class="popup_footer">
      <div class="btn-wrapper">
        <button class="btn_lg btn_cart_lg" id="pr_product_cart_btn" onclick="javascript:optionScript.goSubmit('C');">장바구니</button>
        <button id="direct-buy" class="btn_lg btn_buy_lg" onclick="javascript:optionScript.goSubmit('D');">바로구매</button>
      </div>
    </div>
  </div>
</div>
<!-- //2024.10.15 옵션기능개선-->
<script type="text/javascript">
  function addCartOptSel() {

    var params = [];
    var obj = arguments[0];
    var pcSeq = arguments[1];
    var pbCode = arguments[2];
    var koostProductYN = arguments[6];
    var a = "pb_Code=" + pbCode,
            c = "Y";

    // 테스트
    //pbCode = "003572108"; // 기본옵션
    //  pbCode = "004763361"; // 상품옵션

    if(koostProductYN == null || koostProductYN == ""){
      koostProductYN = "N";
    }

    //쿠폰마케팅 상품 체크
    var cpParam = "pb_Code="+pbCode;
    var cpProductYn = "Y";
    $.ajax({
      type	 : "POST",
      url		 : "/product/cp_product_json.do",
      data	 : cpParam,
      dataType : 'json',
      async    : false,
      success	 : function(data){
        cpProductYn = data.cpProductYn;
      },
      error    : function(data){ alert( "에러가 발생 하였습니다." ); return;}
    });

    var isNotOption = true;

    var i = "pb_Code=" + pbCode,
            d = 1;
    if ($.ajax({
      type: "POST",
      url: "/product/reqOption_json.do",
      data: {"PB_CODE" : pbCode},
      dataType: "json",
      async: !1,
      success: function(e) {
        d = parseInt(e.reqOptionCount, 10)
      },
      error: function(e) {
        alert("에러가 발생 하였습니다.")
      }
    }), d > 0){
      // alert("옵션 선택상품입니다.\n상세페이지에서 옵션을 선택하세요.");
      // return;
      isNotOption = false;
      optionProductBuy(pbCode);
    }

    if(cpProductYn == "Y"){
      alert("장바구니에 담을 수 없는 상품입니다.");
      return;
    }

    //밴드플러스 나눔이벤트 상품 체크
    var isPossibleAddCart = "Y";
    isPossibleAddCart = searchBandNanum(cpParam);

    if(isPossibleAddCart == "N"){
      alert("밴드플러스 전용상품입니다. 지금 바로 신청하고 참여하세요.");
      return;
    }

    //밴드플러스 나눔이벤트 주문 체크
    var isPossibleChekOrder = "N";
    isPossibleChekOrder = searchBandNanumOrder("PB_CODE="+pbCode);

    if(isPossibleChekOrder == "Y"){
      alert("나눔이벤트 상품 구매 가능 최대 횟수는 매월 밴드/쿨밴드 나눔 상품 각각 1개씩 입니다.\r\n다음 달 나눔 이벤트를 기대해 주세요!");
      return;
    }

    //비회원 더반찬 상품 장바구니 담기 체크
    var isTbcAddCart = "N";
    var goTbcCart = true;
    isTbcAddCart = searchTbcProduct("PB_CODE="+pbCode);
    if (isTbcAddCart == "Y"){
      checkLogin().done(function(data){
        if (!data.rst) {
          goTbcCart = false;
          if(confirm("더반찬 배송 상품 주문은\n" +
                  "회원만 이용 가능합니다.\n" +
                  "로그인 하시겠습니까?\n")){
            goLogin('N');
          }
        }
      });

      if(!goTbcCart){
        return;
      }
    }

    if(isNotOption) {
      // 상품옵션
      var PO_SEQs = "";
      // 상품옵션상품
      var OP_SEQs = "";
      // alert(pcSeq);
      params = {
        PB_CODE : pbCode,
        PC_SEQ : pcSeq,
        PB_CNT : 1,
        PO_SEQs : PO_SEQs,
        OP_SEQs : OP_SEQs,
        BP_KOOST_INFO : koostProductYN,
        fnc : "addCartCallback"
      };
      if (arguments.length == 5) {
        var reGularYn = arguments[4];
        // ISNONSTOP
        if (reGularYn == "Y")
          params = {
            PB_CODE : pbCode,
            PC_SEQ : pcSeq,
            PB_CNT : 1,
            PO_SEQs : PO_SEQs,
            OP_SEQs : OP_SEQs,
            BP_KOOST_INFO : koostProductYN,
            EMPLOYEE_MALL_YN_CART : "Y",
            fnc : "addCartCallback"
          };
      }
      if (arguments.length == 6) {
        var isNonStopYn = arguments[5];
        // ISNONSTOP
        if (isNonStopYn == "Y")
          params = {
            PB_CODE : pbCode,
            PC_SEQ : pcSeq,
            PB_CNT : 1,
            PO_SEQs : PO_SEQs,
            OP_SEQs : OP_SEQs,
            BP_KOOST_INFO : koostProductYN,
            "ISNONSTOP" : "Y"
          };
      }

      commonAddCart(params);
      // 장바구니 담기 팝업 효과 추가
      $('.add-to-cart').addClass('add');
      var popTimeOut = function(){
        $('.layer_box').fadeOut();
      }
      setTimeout(popTimeOut,3000);
    }
  }

  function optionProductBuy(pbCode) {
    $.ajax({
      type: "POST",
      url: "/product/" + pbCode + "/ajax_optionProduct.do",
      dataType: "json",
      success: function (data) {
        console.log(data);
        const optionList = data.optionList;
        const optionPrList = data.optionPrList;

        $('#selectOptionWrap').empty();
        var optionHtml = "";

        // 기본옵션
        if (optionList != null && optionList.length > 0) {
          optionList.forEach((option, i) => {
            var productPrice = option.PRICE_ALL_NEW.split('_');
            var personalizedPrice = productPrice[2];
            var leftThisCnt = productPrice[13];  //남은수량
            var maxThisCnt = productPrice[14];  //최대구매허용수량
            const poGrp = option.PO_GRP;

            let leftThisCntYn = 'N';
            if(((option.PB_BI_ORDER_YN == 'Y' && option.PB_COM_CD == '01') || option.PP_POSSIBLE_YN == 'Y') && option.PB_COM_CD != '02') {
              leftThisCntYn = 'Y';
            }

            // 상품가격
            $('#final-price').text(setComma(personalizedPrice));

            optionHtml += "<div class=\"select-box\" data-pogrp=\"" + poGrp + "\">";
            optionHtml += "	<div class=\"select-text\">옵션(" + option.PO_TOP_NAME + ")을 선택해주세요</div>";
            optionHtml += "	<div class=\"arrow\"><i class=\"icon\"></i></div>";
            optionHtml += "</div>";
            var opList = option.OP_LIST;
            optionHtml += "<div class=\"option-list\" data-text=\"옵션(" + option.PO_TOP_NAME + ")을 선택해주세요\" data-pogrp=\"" + poGrp + "\">";
            opList.forEach((opItem, index) => {
              if (opItem.PO_UPPER_SEQ != null && opItem.PO_UPPER_SEQ != '') {
                var soldout = '';
                if (opItem.PO_USE_YN == 'N') {
                  soldout = 'soldout';
                }

                optionHtml += "	<div class=\"option-item " + soldout + "\" data-name=\"옵션 " + index + "\" data-price=\"" + personalizedPrice + "\" data-stock=\"" + leftThisCnt + "\"  data-optionkey=\"" + opItem.PO_SEQ + "\" data-pbcode=\"" + opItem.PB_CODE + "\" data-pbfoodcd=\"" + opItem.PB_FOOD_CD + "\" data-opaddon=\"N\" data-opbasic=\"Y\" data-pogrp=\"" + poGrp + "\" data-leftyn=\"" + leftThisCntYn + "\">";
                optionHtml += "		<div class=\"option-info\">";
                optionHtml += "			<p class=\"product-name\">" + opItem.PO_NAME + "</p>";
                optionHtml += "		</div>";
                optionHtml += "	</div>";
              }
            });
            optionHtml += "</div>";
          });
        }

        // 상품옵션
        if (optionPrList != null && optionPrList.length > 0) {
          optionPrList.forEach((option, i) => {
            const poGrp = option.OP_GRP;
            const opAddonYn = option.OP_ADDON_YN;

            // 상품가격
            $('#final-price').text(0);

            let opTopName = option.OP_TOP_NAME;
            if(opTopName == null || opTopName == '') {
              opTopName = "옵션을 선택해주세요."
              if(opAddonYn == 'N') opTopName += " (필수)"
            }

            optionHtml += "<div class=\"select-box\" data-pogrp=\"" + poGrp + "\">";
            optionHtml += "	<div class=\"select-text\">" + opTopName + "</div>";
            optionHtml += "	<div class=\"arrow\"><i class=\"icon\"></i></div>";
            optionHtml += "</div>";
            var opList = option.OP_LIST;
            optionHtml += "<div class=\"option-list\" data-text=\"" + opTopName + "\" data-pogrp=\"" + poGrp + "\">";
            opList.forEach((opItem, index) => {

              var productPrice = opItem.PRICE_ALL_NEW.split('_');
              var personalizedPrice = productPrice[2];
              var leftThisCnt = productPrice[13];  //남은수량
              var maxThisCnt = productPrice[14];  //최대구매허용수량

              let leftThisCntYn = 'N';
              if(((opItem.PB_BI_ORDER_YN == 'Y' && opItem.PB_COM_CD == '01') || opItem.PP_POSSIBLE_YN == 'Y') && opItem.PB_COM_CD != '02') {
                leftThisCntYn = 'Y';
              }

              var soldout = '';
              let soldoutTxt = '';
              if (opItem.SOLD_OUT_YN == 'Y') {
                soldout = 'soldout';
                soldoutTxt = '(품절)';
              }
              if (personalizedPrice == undefined) {
                personalizedPrice = 0;
                leftThisCnt = 0;
                leftThisCntYn = 'N';
              }
              var folderPath = opResultView(opItem.IMG_CODE);
              optionHtml += "	<div class=\"option-item " + soldout + "\" data-name=\"옵션 " + index + "\" data-price=\"" + personalizedPrice + "\" data-stock=\"" + leftThisCnt + "\"  data-optionkey=\"" + opItem.OP_SEQ + "\" data-pbcode=\"" + opItem.OP_PB_CODE + "\" data-pbfoodcd=\"" + opItem.PB_FOOD_CD + "\" data-opaddon=\"" + opAddonYn  + "\" data-opbasic=\"N\" data-pogrp=\"" + poGrp + "\" data-leftyn=\"" + leftThisCntYn + "\">";
              optionHtml += "		<img src=\"https://img.dongwonmall.com/dwmall/static_root/" + folderPath + "/" + opItem.IMG_CODE + "_" + opItem.IMG_NUM + "_b.jpg\" alt=\"상품 " + index + "\" onerror=\"opOnImgError(this,550)\"/>";
              optionHtml += "		<div class=\"option-info\">";
              optionHtml += "			<p class=\"product-name\">" + opItem.OP_NAME + soldoutTxt + "</p>";
              optionHtml += "			<div class=\"product-info\">";
              optionHtml += "				<p class=\"product-price\">" + setComma(personalizedPrice) + "원</p>";
              if(leftThisCntYn == 'Y') {
                optionHtml += "				<p class=\"product-stock\">" + setComma(leftThisCnt) + "개 남음</p>";
              }
              optionHtml += "			</div>";
              optionHtml += "		</div>";
              optionHtml += "	</div>";

            });
            optionHtml += "</div>";
          });
        }
        optionHtml += "<div class=\"selected-options\" style=\"display: none;\">";
        optionHtml += "</div>";

        optionHtml += "<div class=\"total-price\">";
        optionHtml += "  <small>총</small><span class=\"price\"><strong id=\"final-price\">0</strong>원</span>";
        optionHtml += "</div>";

        $('#selectOptionWrap').html(optionHtml);

        // 선물하기 버튼 숨기기, 나머지 버튼 보이기
        $('div.all-btn > a.btn-gift').hide();
        $('div.all-btn > a:not(.btn-gift)').show();

        opPopupOpen();
      },
      error: function (e) {
        alert("옵션상품을 가져오는데 에러가 발생 하였습니다.");
      }
    });
  }

  function opResultView(imgCode){
    var folder = "";
    var folderPath = "";

    if(imgCode != null) {
      var imgCodeLen = imgCode.length;

      if (imgCodeLen == 5){
        folder = "model_img/main/";
        folderPath = imgCode.substr(0, 3);
      } else if(imgCodeLen == 7){
        folder = "model_img/main/";
        folderPath = imgCode.substr(0, 3);
      }else if(imgCodeLen == 6){
        folder = "set_img/main/";
        folderPath = imgCode.substr(0, 4);
      }else if(imgCodeLen == 12){
        folder = "pick_img/main/";
        folderPath = imgCode.substr(0, 6);
      }else if(imgCodeLen == 9){
        folder = "product_img/main/";
        folderPath = imgCode.substr(0, 7);
      }
    }
    return folder+folderPath;
  }

  function opOnImgError(elm, size){
    if(size){
      elm.src = "https://img.dongwonmall.com/dwmall/static_root/no_img/no_product"+size+".jpg";
    }else{
      elm.src = "https://img.dongwonmall.com/dwmall/static_root/no_img/no_product550.jpg";
    }
  }

</script>
