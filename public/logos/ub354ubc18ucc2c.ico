				var latelySwiper = new Swiper(".latelySwiper", {
					slidesPerView: 3,
					spaceBetween: 10,
					slidesPerGroup: 3,
					pagination: {
					  el: ".latelySwiper-pn",
					  type: "fraction",
					},
					navigation: {
					  nextEl: ".lately-sub .next",
					  prevEl: ".lately-sub .prev",
					},
					allowTouchMove: false,
					observer: true,
					observeParents: true,	
				});
			},
			error : function(data){return;}
		});
		//}
		}); 
		
