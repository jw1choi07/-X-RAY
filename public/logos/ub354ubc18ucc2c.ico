    </script><!-- 브레이즈 script -->
		<!-- 개발, 운영 모두 진행 -->
		<!-- 앱메시지 : type - brazeCustomEvents, brazeCustomAttributes 구분 필수 -->
<!-- 앱메시지 : eventName - type이 BrazeCustomEvents일 경우, EventName 추가 필수 -->
<script type="text/javascript">

    try {
        var _offset = 1000 * 60 * 60 * 9; // 9시간 밀리세컨트 값
        //var _korNow = new Date(Date.now() + _offset);
        var _korNow = new Date(Date.now());
        var BRAZE_GUEST_CM_SEQ = "9999999999999999";
        var BRAZE_SESSION_CM_SEQ = "";
        var BRAZE_AIRBRIDGE_SYNC_MAX_RETRY = 5;
        var BRAZE_AIRBRIDGE_SYNC_RETRY_DELAY_MS = 500;
        var getString = function (value) {
            if (value == null) {
                return "";
            }
            return String(value);
        };
        var BRAZE_AIRBRIDGE_UTM_CACHE_KEY = "braze_airbridge_utm_cache_v1";
        var BRAZE_AIRBRIDGE_UTM_CACHE_TTL_MS = 7 * 24 * 60 * 60 * 1000;
        var firstNonEmpty = function () {
            for (var i = 0; i < arguments.length; i++) {
                var value = getString(arguments[i]);
                if (value != "") {
                    return value;
                }
            }
            return "";
        };
        var getLocationSearchParams = function () {
            try {
                if (window.location == undefined || window.location.search == undefined) {
                    return null;
                }
                return new URLSearchParams(window.location.search);
            } catch (e) {
                return null;
            }
        };
        var decodeUriComponentSafe = function (value) {
            var decodedValue = getString(value);
            for (var i = 0; i < 2; i++) {
                try {
                    var nextDecodedValue = decodeURIComponent(decodedValue);
                    if (nextDecodedValue == decodedValue) {
                        break;
                    }
                    decodedValue = nextDecodedValue;
                } catch (e) {
                    break;
                }
            }
            return decodedValue;
        };
        var getAirbridgeReferrerParams = function () {
            var result = {};
            var searchParams = getLocationSearchParams();
            if (searchParams == null) {
                return result;
            }

            var airbridgeReferrer = getString(searchParams.get("airbridge_referrer"));
            if (airbridgeReferrer == "") {
                return result;
            }

            var decodedReferrer = decodeUriComponentSafe(airbridgeReferrer);
            if (decodedReferrer == "") {
                return result;
            }

            try {
                var referrerParams = new URLSearchParams(decodedReferrer);
                referrerParams.forEach(function (value, key) {
                    result[key] = value;
                });
            } catch (e) {
                return {};
            }

            return result;
        };
        var getUrlUtmParams = function () {
            var searchParams = getLocationSearchParams();
            if (searchParams == null) {
                return {};
            }

            return {
                utm_source: getString(searchParams.get("utm_source")),
                utm_campaign: getString(searchParams.get("utm_campaign")),
                utm_medium: getString(searchParams.get("utm_medium"))
            };
        };
        var getAirbridgeCacheStorageKey = function (cmSeq) {
            var normalizedCmSeq = getString(cmSeq);
            var suffix = "guest";
            if (normalizedCmSeq != "" && normalizedCmSeq != BRAZE_GUEST_CM_SEQ) {
                suffix = normalizedCmSeq;
            }
            return BRAZE_AIRBRIDGE_UTM_CACHE_KEY + ":" + suffix;
        };
        var getAirbridgeAttrCache = function (cmSeq) {
            try {
                var cachedValue = localStorage.getItem(getAirbridgeCacheStorageKey(cmSeq));
                if (cachedValue == null || cachedValue == "") {
                    return {};
                }
                var parsedValue = JSON.parse(cachedValue);
                if (parsedValue != null && parsedValue.attrs != undefined) {
                    var savedAt = Number(parsedValue.savedAt || 0);
                    if (savedAt <= 0 || (Date.now() - savedAt) > BRAZE_AIRBRIDGE_UTM_CACHE_TTL_MS) {
                        localStorage.removeItem(getAirbridgeCacheStorageKey(cmSeq));
                        return {};
                    }
                    return parsedValue.attrs || {};
                }
                return parsedValue || {};
            } catch (e) {
                return {};
            }
        };
        var setAirbridgeAttrCache = function (cmSeq, attrs) {
            try {
                localStorage.setItem(getAirbridgeCacheStorageKey(cmSeq), JSON.stringify({
                    savedAt: Date.now(),
                    attrs: attrs
                }));
            } catch (e) {
            }
        };
        var isSameAirbridgeAttrs = function (leftAttrs, rightAttrs) {
            return getString(leftAttrs.utm_channel) == getString(rightAttrs.utm_channel)
                && getString(leftAttrs.utm_subpublisher) == getString(rightAttrs.utm_subpublisher)
                && getString(leftAttrs.utm_campaign) == getString(rightAttrs.utm_campaign)
                && getString(leftAttrs.utm_ad_group) == getString(rightAttrs.utm_ad_group)
                && getString(leftAttrs.utm_ad_creative) == getString(rightAttrs.utm_ad_creative);
        };
        var getAirbridgeAttributionAttrs = function (resource) {
            var attributionData = resource && resource.attributionData ? resource.attributionData : {};
            var attributionResult = resource && resource.attributionResult ? resource.attributionResult : {};
            if (Object.keys(attributionResult).length == 0) {
                attributionResult = attributionData && attributionData.attributionResult ? attributionData.attributionResult : {};
            }

            var referrerParams = getAirbridgeReferrerParams();
            var urlUtmParams = getUrlUtmParams();

            return {
                "utm_channel": firstNonEmpty(attributionResult.attributedChannel, referrerParams.channel, urlUtmParams.utm_source),
                "utm_subpublisher": firstNonEmpty(attributionResult.attributedSubPublisher, referrerParams.sub_id, referrerParams.sub_publisher, referrerParams.medium, urlUtmParams.utm_medium),
                "utm_campaign": firstNonEmpty(attributionResult.attributedCampaign, referrerParams.campaign, urlUtmParams.utm_campaign),
                "utm_ad_group": firstNonEmpty(attributionResult.attributedAdGroup, referrerParams.ad_group),
                "utm_ad_creative": firstNonEmpty(attributionResult.attributedAdCreative, referrerParams.ad_creative)
            };
        };

        var brazeScript = {
            app: function (brazeJson) {    // APP 전송
                // APP 전송 없음(모바일만 전송)
                // if (window.webkit != undefined) {//iOS
                //     if (window.webkit.messageHandlers.brazeEvent != undefined) {
                //         window.webkit.messageHandlers.brazeEvent.postMessage(JSON.stringify(brazeJson));
                //     }
                // }
                // if (window.brazeEvent != undefined) {//Android
                //     window.brazeEvent.postMessage(JSON.stringify(brazeJson));
                // }
            },
            eventApply: function (eSeq) {   // 이벤트 응모
                if (isApp == "Y") {
                    var brazeJson = {type: "brazeCustomAttributes"};
                    brazeJson["event_list"] = eSeq;
                    brazeScript.app(brazeJson);
                } else {
                    braze.getUser().addToCustomAttributeArray("event_list", eSeq);
                }
            },
            eventResisterApply: function (eNm, eSeq, sdate, edate) {   // 체험단 응모
                var brazeJson = {};
                brazeJson["event_category"] = "체험단";
                brazeJson["event_name"] = eNm;
                brazeJson["event_id"] = eSeq;
                brazeJson["date_start"] = sdate;
                brazeJson["date_end"] = edate;

                if (isApp == "Y") {
                    brazeJson["type"] = "brazeCustomEvents";
                    brazeJson["eventName"] = "register_event_tester";
                    brazeScript.app(brazeJson);
                } else {
                    brazeJson["date_start"] = sdate;
                    brazeJson["date_end"] = edate;
                    braze.logCustomEvent("register_event_tester", brazeJson);
                }
            },
            login: function (method, cmSeq) {   // 로그인
                if (isApp == "Y") {
                    var brazeJson = {type: "brazeCustomAttributes", external_id: cmSeq};
                    brazeScript.app(brazeJson);
                    brazeJson = {type: "brazeCustomAttributes", last_login_method: method, last_login_date: _korNow};
                    brazeScript.app(brazeJson);
                } else {
                    braze.changeUser(cmSeq);
                    braze.getUser().setCustomUserAttribute("last_login_method", "web");
                    braze.getUser().setCustomUserAttribute("last_login_date", _korNow);
                }

                // Airbridge attribution 값을 로그인 사용자 Braze 속성으로 즉시 동기화
                brazeScript.syncAirbridgeAttribution({cmSeq: cmSeq, force: true});
            },
            withdrawal: function () {   // 회원탈퇴
                if (isApp == "Y") {
                    var brazeJson = {type: "brazeCustomAttributes"};
                    brazeJson["is_deleted"] = true;
                    brazeScript.app(brazeJson);
                } else {
                    braze.getUser().setCustomUserAttribute("is_deleted", true);
                }
            },
            emailNotiModify: function (t, l) { //  이메일수신정보 수정
                var type = braze.User.NotificationSubscriptionTypes.UNSUBSCRIBED;
                var smsYn = 'false';
                var emailYn = 'false';
                if (t == 'Y') {
                    type = braze.User.NotificationSubscriptionTypes.OPTED_IN;
                    emailYn = 'true';
                }
                if (l == 'Y') {
                    smsYn = 'true';
                }

                if (isApp == "Y") {
                    var brazeJson = {type: "brazeCustomAttributes"};
                    brazeJson["EmailNotificationSubscriptionType"] = type;
                    brazeJson["lms_advertise_allow"] = smsYn;
                    brazeJson["email_advertise_allow"] = emailYn;
                    brazeJson["last_advertise_allow_date"] = _korNow;
                    brazeScript.app(brazeJson);
                } else {
                    braze.getUser().setEmailNotificationSubscriptionType(type);
                    braze.getUser().setCustomUserAttribute("lms_advertise_allow", smsYn);
                    braze.getUser().setCustomUserAttribute("email_advertise_allow", emailYn);
                    braze.getUser().setCustomUserAttribute("last_advertise_allow_date", _korNow);
                }
            },
            addToWish: function (p) {   // 찜하기 추가
                // console.log('addToWish: ' + p);
                if (isApp == "Y") {
                    var brazeJson = {type: "brazeCustomAttributes"};
                    brazeJson["like_list"] = p;
                    brazeScript.app(brazeJson);
                } else {
                    braze.getUser().addToCustomAttributeArray("like_list", p);
                }
            },
            deleteToWish: function (p) {   // 찜하기 추가
                console.log('deleteToWish: ' + p);
                if (isApp == "Y") {
                    var brazeJson = {type: "brazeCustomAttributes"};
                    brazeJson["like_list"] = p;
                    brazeScript.app(brazeJson);
                } else {
                    braze.getUser().removeFromCustomAttributeArray("like_list", p);
                }
            },
            deliveryLocation: function (a) {    // 기본배송지 수정/추가
                a = a.split(' ');
                if (a.length > 2) {
                    var location1 = a[0];
                    var location2 = a[1];
                    if (isApp == "Y") {
                        var brazeJson = {type: "brazeCustomAttributes"};
                        brazeJson["location_1"] = location1;
                        brazeJson["location_2"] = location2;
                        brazeScript.app(brazeJson);
                    } else {
                        braze.getUser().setCustomUserAttribute("location_1", location1);
                        braze.getUser().setCustomUserAttribute("location_2", location2);
                    }
                }
            },
            review: function (pbNm, pbCode, rate) {   // 리뷰작성
                var brazeJson2 = {};
                brazeJson2["product_name"] = pbNm;
                brazeJson2["product_id"] = pbCode;
                brazeJson2["rate"] = rate;

                if (isApp == "Y") {
                    var brazeJson = {type: "brazeCustomAttributes"};
                    brazeJson["total_review_count"] = 1;
                    brazeScript.app(brazeJson);

                    brazeJson2["type"] = "brazeCustomEvents";
                    brazeJson2["eventName"] = "review_done";
                    brazeScript.app(brazeJson2);
                } else {
                    braze.getUser().incrementCustomUserAttribute("total_review_count", 1);
                    braze.logCustomEvent("review_done", brazeJson2);
                }
            },
            relayCheck: function (c) {   // 출석체크
                var attendDateCount = c;
                var brazeJson = {};
                brazeJson["attend_date"] = _korNow;
                brazeJson["attend_date_count"] = attendDateCount;
                if (isApp == "Y") {
                    brazeJson["type"] = "brazeCustomEvents";
                    brazeJson["eventName"] = "check_attendance";
                    brazeScript.app(brazeJson);
                } else {
                    braze.logCustomEvent("check_attendance", brazeJson);
                }
            },
            brandHall: function (name, id) {    // 전문관 클릭
                if (name != undefined && name != '') {
                    var brazeJson = {};
                    brazeJson["brand_hall_name"] = name;
                    //brazeJson["brand_hall_id"] = id;
                    // console.log('name: ' + name);
                    if (isApp == "Y") {
                        brazeJson["type"] = "brazeCustomEvents";
                        brazeJson["eventName"] = "view_page_special-hall";

                        brazeScript.app(brazeJson);
                    } else {
                        braze.logCustomEvent("view_page_special-hall", brazeJson);
                    }
                }
            },
            addCart: function (id, name, price, img, option, isDeal, isDlive, isFreeShip, isOutlet) {
                var brazeJson = {};

                brazeJson["product_id"] = id;
                brazeJson["product_name"] = name;
                brazeJson["product_price"] = price;
                brazeJson["img_url"] = img;
                brazeJson["product_option"] = option;
                brazeJson["is_d-day-deal"] = isDeal;
                brazeJson["is_d-live"] = isDlive;
                brazeJson["is_free_ship"] = isFreeShip;
                brazeJson["is_outlet"] = isOutlet;

                // console.log('addCart brazeJson: ' + JSON.stringify(brazeJson));

                if (isApp == "Y") {
                    brazeJson["type"] = "brazeCustomEvents";
                    brazeJson["eventName"] = "add_cart";
                    brazeScript.app(brazeJson);
                } else {
                    braze.logCustomEvent("add_cart", brazeJson);
                }
            },
            deleteCart: function (id, name) {
                var brazeJson = {};

                brazeJson["product_id"] = id;
                brazeJson["product_name"] = name;

                console.log('brazeJson: ' + JSON.stringify(brazeJson));

                if (isApp == "Y") {
                    brazeJson["type"] = "brazeCustomEvents";
                    brazeJson["eventName"] = "delete_cart";
                    brazeScript.app(brazeJson);
                } else {
                    braze.logCustomEvent("delete_cart", brazeJson);
                }
            },
            view_cart: function (brazeJson) {
                if (isApp == "Y") {
                    // Events
                    brazeJson["type"] = "brazeCustomEvents";
                    brazeJson["eventName"] = "view_cart";
                    brazeScript.app(brazeJson);
                } else {
                    // Events
                    braze.logCustomEvent("view_cart", brazeJson);
                }
            },
            tryGift: function (id, name, price, img, option, isDeal, isDlive, isFreeShip, isOutlet) {
                var brazeJson = {};

                brazeJson["product_id"] = id;
                brazeJson["product_name"] = name;
                brazeJson["product_price"] = price;
                // brazeJson["img_url"] = img;
                // brazeJson["product_option"] = option;
                // brazeJson["is_d-day-deal"] = isDeal;
                // brazeJson["is_d-live"] = isDlive;
                // brazeJson["is_free_ship"] = isFreeShip;
                // brazeJson["is_outlet"] = isOutlet;

                console.log('tryGift brazeJson: ' + JSON.stringify(brazeJson));

                if (isApp == "Y") {
                    brazeJson["type"] = "brazeCustomEvents";
                    brazeJson["eventName"] = "try_present_product";
                    brazeScript.app(brazeJson);
                } else {
                    braze.logCustomEvent("try_present_product", brazeJson);
                }
            },
            isSend: function (cookieName, gubun, expiredays) {
                // 중복으로 보내지 않게 위해 쿠키에 gubun값(예: 주문번호)을 저장한다.
                var isSend = true;
                var brazeCookie = getCookie(cookieName);
                if(brazeCookie != '' && brazeCookie != null) {
                    if(brazeCookie == gubun) {
                        isSend = false;
                    }
                }
                var todayDate = new Date();
                todayDate = new Date(parseInt(todayDate.getTime() / 86400000) * 86400000 + 54000000); // 1일
                if (todayDate > new Date()) {
                    expiredays = expiredays - 1;
                }
                todayDate.setDate(todayDate.getDate() + expiredays);
                document.cookie = cookieName + "=" + gubun + "; path=/; expires=" + todayDate.toGMTString() + ";";

                return isSend;
            },
            api: function (key, value) {
                $.ajax({
                    type: "POST",
                    url: "/common/ajax_braze_api.do",
                    data: {"key": key, "value": value},
                    dataType: "json"
                });
            },
            setAirbridgeAttributionToBraze: function (attrs, isMember) {
                var keys = Object.keys(attrs);
                var attrKeys = [];
                var i = 0;

                for (i = 0; i < keys.length; i++) {
                    if (attrs[keys[i]] != "") {
                        attrKeys.push(keys[i]);
                    }
                }

                if (attrKeys.length === 0) {
                    return false;
                }

                if (isApp == "Y") {
                    var appBrazeJson = {type: "brazeCustomAttributes"};
                    for (i = 0; i < attrKeys.length; i++) {
                        appBrazeJson[attrKeys[i]] = attrs[attrKeys[i]];
                    }
                    brazeScript.app(appBrazeJson);
                } else {
                    for (i = 0; i < attrKeys.length; i++) {
                        braze.getUser().setCustomUserAttribute(attrKeys[i], attrs[attrKeys[i]]);
                    }
                }

                if (isMember) {
                    for (i = 0; i < attrKeys.length; i++) {
                        brazeScript.api(attrKeys[i], attrs[attrKeys[i]]);
                    }
                }
                return true;
            },
            syncAirbridgeAttribution: function (options) {
                options = options || {};
                var forceSync = options.force === true;
                var retryCount = Number(options.retryCount || 0);
                if (isNaN(retryCount) || retryCount < 0) {
                    retryCount = 0;
                }
                var cmSeq = getString(options.cmSeq);
                var isMember = false;
                var retrySync = function () {
                    if (retryCount >= BRAZE_AIRBRIDGE_SYNC_MAX_RETRY) {
                        return false;
                    }
                    var nextOptions = {
                        cmSeq: cmSeq,
                        force: forceSync,
                        retryCount: retryCount + 1
                    };
                    setTimeout(function () {
                        brazeScript.syncAirbridgeAttribution(nextOptions);
                    }, BRAZE_AIRBRIDGE_SYNC_RETRY_DELAY_MS);
                    return true;
                };

                if (cmSeq == "") {
                    cmSeq = getString(BRAZE_SESSION_CM_SEQ);
                }

                if (cmSeq != "" && cmSeq != BRAZE_GUEST_CM_SEQ) {
                    isMember = true;
                }
                if (window.airbridge == undefined || typeof airbridge.fetchResource !== "function") {
                    retrySync();
                    return;
                }

                airbridge.fetchResource(function (resource) {
                    try {
                        var attrs = getAirbridgeAttributionAttrs(resource);
                        if (attrs.utm_channel == "" && attrs.utm_subpublisher == "" && attrs.utm_campaign == "" && attrs.utm_ad_group == "" && attrs.utm_ad_creative == "") {
                            return;
                        }

                        var cachedAttrs = getAirbridgeAttrCache(cmSeq);
                        if (!forceSync && isSameAirbridgeAttrs(attrs, cachedAttrs)) {
                            return;
                        }

                        setAirbridgeAttrCache(cmSeq, attrs);
                        brazeScript.setAirbridgeAttributionToBraze(attrs, isMember);
                    } catch (err) {
                        return;
                    }
                });
            }
        };

        // 페이지 진입 시 Airbridge attribution -> Braze custom attribute 동기화
        brazeScript.syncAirbridgeAttribution();

        // 장바구니 담기(메인추천, 카테고리, )
        $(document).on("click", '.btn_cart', function (e) {
            var id = $(this).data('item-id');
            var name = $(this).data('item-name');
            var price = $(this).data('item-price');
            var img = $(this).parents().parents().find('.thumb img').attr('src');
            brazeScript.addCart(id, name, price, img, [], false, false, false, false);
        });
        // 찜 하기(메인추천, 카테고리, )
        $(document).on("click", '.btn_like', function (e) {
            // 위시리스트 추가
            var id = $(this).siblings('.btn_cart').data('item-id');
            var c = $(this).attr("class");
            if (c != undefined && c.indexOf('liked') > -1) {
                brazeScript.addToWish(id);
            } else {
                brazeScript.deleteToWish(id);
            }
        });

        // 장바구니 담기(아울렛, 기획전)
        $('html').click(function (e) {
            if ($(e.target).parents().hasClass('cart')) {
                // console.log('.cart lycurrent click')
                var isOutlet = false;
                var id = $(e.target).parent().parent().attr('data-item-id');
                var name = $(e.target).parent().parent().attr('data-item-name');
                var price = $(e.target).parent().parent().attr('data-item-price');
                var img = $(e.target).parent().parent().parent().find('.pic img').attr('src');
                
                if (id == undefined || id == null || id == '') {
                    // 기획전
                    id = $(e.target).parent().parent().parent().attr('data-item-id');
                    name = $(e.target).parent().parent().parent().attr('data-item-name');
                    price = $(e.target).parent().parent().parent().attr('data-item-price');
                    img = $(e.target).parent().parent().parent().find('.pic img').attr('src');
                }
                if (id != undefined && id != null && id != '') {
                    brazeScript.addCart(id, name, price, img, [], false, false, false, isOutlet);
                }
            }
        });

        // GNB
        $(document).ready(function () {
            var gnbNm = $('head > title').text();
            if (gnbNm != undefined && gnbNm != null && gnbNm != '') {
                var brazeJson = {};
                brazeJson["name"] = gnbNm;

                if (isApp == "Y") {
                    brazeJson["type"] = "brazeCustomEvents";
                    brazeJson["eventName"] = "view_gnb";

                    brazeScript.app(brazeJson);
                } else {
                    braze.logCustomEvent("view_gnb", brazeJson);
                }
            }
        });

        // 전문관 조회
        
            var ccSeq = '01110050';
            if (ccSeq == '01110018') {
                brazeScript.brandHall('동원', '01110018');
            }
            if (ccSeq == '01110050') {
                brazeScript.brandHall('더반찬', '01110050');
            }
        

        /**
         * 회원가입
         */
        

