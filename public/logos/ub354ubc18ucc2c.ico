		function shareUrl(){
			let currentUrl = window.document.location.href;

			let t = document.createElement("textarea");
			document.body.appendChild(t);
			t.value = currentUrl;
			t.select();

			document.execCommand("copy");
			document.body.removeChild(t);
			alert('URL이 복사되었습니다.');

			airbridgeScript.share(currentUrl, 'URL복사');
		}

		$(document).ready(function() {
			
			if($("#lnb").length>0){$("#skipNavi_lnb").show();};
			if($("#mnb").length>0){$("#skipNavi_mnb").show();};
	
			/* CSTONE : 201409 */
			//이 상품과 함께 구매한 상품
			slideProType2("#cartprotogets", "#cartprotogets_btn", 1, 400);
			/* CSTONE : 201409 */
	
			
	
			// 장바구니 갯수 설정
			$.ajax({
				type : "POST",
				url : "/order/cart/jsonCartListCount.do",
				dataType : 'json',
				success : function(data) {
					$("#cartListCount").html(data.result);
				},
				error : function(data) {
				}
			});
			
			// 전문관 아이콘 호출
		 	$.ajax({
				type:"post",
				dataType:"json",
				url: "/category/iconList_json.do",
				success: 
					function(item){
						var result = item.specialIcon;
						var html = "";
						var no_display = ['54']
						$.each(result, function(index, item) {
							var check = true;
							for(idx in no_display){
								if(no_display[idx] === item.M_CD){
									check = false;
									break;
								}
							}
							if(check){
								html += '<a href="' + item.PAGE_URL  + '" title="' + item.MENU_NM + '">';
						        html += '<img src="https://img.dongwonmall.com/' + item.ICON_URL + '" alt="전문관"></img>';
						        html += '<p>' + item.MENU_NM + '</p>';
						        html += '</a>';
							}
						});
						$(".mall_dropdown").append(html);
					},
			  	error : function () {
					alert("전문관 아이콘 생성 에러");
				}
			});
			
		 	//전문관 레이어 정보 가져오기(공통코드에서관리)
			$.ajax({
				type:"post",
				dataType:"json",
				url: "/display/specialLayer_json.do",
				success: 
					function(item){
						if(item.specialThumbnail){
							$.each(item.specialThumbnail,function(i, m){
								var isNew = (m.ETC=='Y' ? 'new':'');
								var isOn = '';
								if('cate_id=01110050'!=''){
									isOn = ((m.REF3).indexOf('cate_id=01110050') > -1 ? 'style="font-weight:bold;"':'');
								}else{
									isOn = ((m.REF3).indexOf('/category/special.do') > -1 ? 'style="font-weight:bold;"':'');
									
									//츄츄 예외처리
									if(('/category/special.do').indexOf('chuchew') > -1 && (m.REF3).indexOf('chuchew') > -1){
										isOn = 'style="font-weight:bold;"';
									}
								}
								
								if(m.REF1 && (m.ORDER_SEQ % 100 == 0)){
									var html = '<li class="mall_item">'
					                        +'<a href="'+m.REF3+'" '+isOn+' class="link">'
					                        +'<span class="mall_logo"><img src="https://img.dongwonmall.com/'+m.REF1+'" width="40" height="40" alt="" aria-hidden="true"></span>'
					                        +'<span class="'+isNew+'">'+m.CODE_NM+'</span>'
					                        +'</a>'
					                        +'</li>';
									$('div.mall_box div.mall div.mall_cont ul.mall_list.1depth').append(html);
								}else{
									var html = '<a class="item_depth" href="'+m.REF3+'&chuchewDelYn=Y">'
					                        +'<strong class="'+isNew+'">'+m.CODE_NM+'</strong>'
					                        +'</a>';
									$('div.mall_box div.mall div.mall_cont ul.mall_list li:first-child').append(html);
								}
							});
						}
					    $('.mall_list li:first-child a.link').append('<span id="togglebtn"></span>');

					    var $mallList      = $('div.mall_box div.mall div.mall_cont ul.mall_list.1depth');
					    var $firstMallItem = $mallList.find('li.mall_item:first');

					    $firstMallItem.on('mouseenter', function () {
					        $mallList.find('.item_depth').addClass('show');
					    });

					    $mallList.on('mouseleave', function () {
					        $mallList.find('.item_depth').removeClass('show');
					    });
					},
			  	error : function () {
					console.log("전문관 레이어 정보 가져오기 에러");
				}
			});

		});
		
		$(window).load(function(){
		//팝업 초기 설정~~~
		headerPopInit();
		
		
		
		});
		
