		if(navigator.userAgent.match(/showAppleLogin/)){
			isApple='Y';
		}
		var koost_cid = getCookie("koost_cid");
		// 쿠키값이 존재하지 않으면 생성
		if(koost_cid == null || koost_cid == ""){
		var n = new Date();
		var p1 = n.getTime();
		var p2 = Math.random().toString(16).slice(2, 10);
		var expire = new Date();
		expire.setDate(expire.getDate() + 3000);
		var cookies = "koost_cid=" + (p1 + "|" + p2) + "; path=/;" + " expires=" + expire.toGMTString() + ";";
		document.cookie = cookies;
		}
		</script>

