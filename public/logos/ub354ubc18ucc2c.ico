<div class="ai-bot-btn-wrap">
	<span class="reco-txt" style="display: none;">최근 주문 배송, 바로
		확인하세요!</span> <a href="javascript:void(0);"
                         onclick="
                                 if ($('#layerChatbotSori').hasClass('show')) {
                                 hideLayerPopup('layerChatbotSori');
                                 } else {
                                 if (window.DwChatbot && window.DwChatbot.openFromButton) {
                                 window.DwChatbot.openFromButton(window.location.href, 'false');
                                 }
                                 }
                                 return false;
                                 "
                         class="ai-bot-btn" id="aiBotBtn" aria-label="AI 쇼핑 어시스턴트"
                         style="display: none"> <span class="hidden">ai 챗봇 바로가기</span>
</a>
</div>
<!-- //2026 ai 챗봇버튼 -->
<script>
    (function () {
        const recoTxt = document.querySelector('.reco-txt');
        const aiBotBtn = document.getElementById('aiBotBtn');
        // 비회원 인증 상태(세션 있으나 CM_SEQ=9999999999999999)는 false, 비로그인/일반회원은 true
        const isLogin = true;
        const nonMem = true;
        const aiAccess = 'N';
        const chatbotOpenAll = 'Y';

        if (nonMem && (chatbotOpenAll === 'Y' || aiAccess === 'Y')) {
            $('#aiBotBtn').show();

            // reco-txt 경로별 텍스트 로드
            (function loadRecoText() {
                const pathname = window.location.pathname;
                let pageUrl = '';

                if (pathname === '/' || pathname === '/index.do' || pathname.indexOf('/display/band.do') === 0 || pathname.indexOf('/category/special.do') === 0 ||
                    pathname.indexOf('/category/list.do') === 0 || pathname.indexOf('/product/detail.do') === 0 || pathname.indexOf('/order/cart/list.do') === 0 ||
                    pathname.indexOf('/search/search.do') === 0) {
                    pageUrl = pathname;
                }

                if (!pageUrl) return;

                $.ajax({
                    url: '/chatbot/internal/chat/recoText.do',
                    type: 'GET',
                    data: { page_url: pageUrl },
                    dataType: 'json',
                    success: function (res) {
                        var text = res && res.reco_text ? res.reco_text : '';
                        if (text) {
                            $('.reco-txt').text(text).show();
                        }
                    }
                });
            })();
        }else{
            $('#aiBotBtn').hide();
        }

        if (window.location.pathname.indexOf('/event/relayCheck.do') === 0) {
            $('#aiBotBtn').hide();
            $('.reco-txt').hide();
        }

        if (window.location.pathname.indexOf('/order/order/orderForm.do') === 0) {
            $('#aiBotBtn').hide();
            $('.reco-txt').hide();
        }

        recoTxt.addEventListener('click', function () {
            aiBotBtn.click();
        });
    })();
</script>
<!-- //2026 ai 챗봇버튼 -->
