					<!-- 로그인 -->
					<div class="id_wrap mt24">
						<script type="text/javascript">
						var html = '';
/*
						var isLogin = false;
						try {
							isLogin = isMelonLogin();
						} catch (e) {
							alert("member script import error!!");
						}
 */

						if (isMelonLogin()) {
							var prodName = "보유중인 이용권이 없습니다.";;
							var prodNames = '';
							var pocId = "XXXX";

							var mainCouponCnt = '';
							var mainMelonCash = '';
							var mainMemberGiftCnt = '';

							$.ajax({
								url   : '/main/getMemberInfo.json?pocId=' + pocId +'&memberKey='+ getMemberKey(),
								type  : 'GET',
								async : false
							}).done(function(data) {
								if(typeof data.RESPONSEENTITY != 'undefined'){
									prodNames = data.RESPONSEENTITY.product[0] != null ? data.RESPONSEENTITY.product[0] : '';
									mainCouponCnt = data.RESPONSEENTITY.coupon != null ? data.RESPONSEENTITY.coupon : '';
									mainMelonCash = data.RESPONSEENTITY.cash != null ? data.RESPONSEENTITY.cash : '';
									mainMemberGiftCnt = data.RESPONSEENTITY.gift != null ? data.RESPONSEENTITY.gift : '';
								}

								if(typeof prodNames == 'undefined' || prodNames  == null || prodNames == ''){
									prodNames = '';
								}else {
									prodName = '<a href="javascript:melon.menu.goMyPage();" title="이용권보유현황">'
												+ '<span class="box_name"><strong><span>'+ prodNames +'</span></strong> 사용중</span>'
												+ '</a>';
								}
							}).fail(function(){
								prodNames = '';
							});

							var memberKey = getMemberKey()
							var memberInfo = svcMember.displayIdByMemberKey(memberKey);
							var memberType = svcMember.getMemberType().MEMBERTYPE;
							var gradeInfo = svcMember.gradeInfoByMemberKey(memberKey);

							var memId = '';
							if(memberType == undefined || memberType == null){
								memberType = '0';
							}

							if(memberInfo.DISPLAYID != undefined || memberInfo.DISPLAYID != null){
								memId = memberInfo.DISPLAYID;
							}

							if(memId.indexOf("@") != -1 && memberType != '1'){//카카오계정이 아닌경우에만 @도메인 영역 삭제처리
								memId = memId.split("@")[0];
							}

							var fromMPS = getCookie("MPS"); // 멜론 플레이어에서 왔는지 확인.
							var fromMPSYn = fromMPS == null || fromMPS.indexOf("MELONPLAYER") < 0;

							var gradeImg = "";
							var gradeName = gradeInfo.GRADE;
							var myinfoPage = "https://member.melon.com/muid/web/help/myinfointro_inform.htm";

							if(gradeName == undefined || gradeName == null){
								gradeName = '일반';
							}

							try {
								if(gradeName == '일반'){
									gradeImg = "";
								} else if(gradeName == 'GREEN'){
									gradeImg = "<span class=\"icon-comm grade-green\"></span>";
								} else if(gradeName == 'SILVER'){
									gradeImg = "<span class=\"icon-comm grade-silver\"></span>";
								} else if(gradeName == 'GOLD'){
									gradeImg = "<span class=\"icon-comm grade-gold\"></span>";
								} else if(gradeName == 'VIP'){
									gradeImg = "<span class=\"icon-comm grade-vip\"></span>";
								} else if(gradeName == 'MVIP'){
									gradeImg = "<span class=\"icon-comm grade-mvip\"></span>";
								}

								//카카오연동확인
								if(memberType == '1'){
									gradeImg += "<span class=\"icon-comm icon-kakao\"></span>";
								}

							} catch (e) {}


							html = ['<div class="logout_wrap">',
									<!-- 140603_수정 -->
									'<div class="mem_info">',
										'<strong><span class="id_area"><span class="icon_area">' + gradeImg + '</span>'+ memId + '</span>님 </strong>',
										'<a href="'+myinfoPage+'" title="내정보"><span>내정보</span></a>',
										fromMPSYn ? '<a href="javascript:MELON.WEBSVC.POC.login.gnbLogout();" onclick="MELON.WEBSVC.POC.login.gnbLogout();" title="로그아웃" class="btn_logout"><span>로그아웃</span></a>' : '',
									'</div>',
									prodNames == '' ? '<span class="btn_buy"><a href="javascript:melon.menu.cm.goPamphlet();" title="이용권구매" >이용권구매</a></span>' : '',
									'<div class="mem_used">',
										'<strong class="product_name">'+prodName+'</strong>',
										'<ul>',
											'<li class="nth1">',
												'<a href="javascript:melon.link.goMyCupon();">',
													'<span><span class="label">쿠폰</span><span class="nm">'+ mainCouponCnt +'</span></span>',
												'</a>',
											'</li>',
											'<li class="nth2">',
												'<a href="javascript:melon.link.goMelonCash();">',
													'<span><span class="label">캐시</span><span class="nm">'+ mainMelonCash.toString().replace(/(\d)(?=(?:\d{3})+$)/g, "$1,") +'</span></span>',
												'</a>',
											'</li>',
											'<li class="nth3">',
												'<a href="javascript:melon.link.goPresentSong();">',
													'<span><span class="label">선물</span><span class="nm">'+ mainMemberGiftCnt +'</span></span>',
												'</a>',
											'</li>',
										'</ul>',
									'</div>',
								'</div>'].join('');

							document.write(html);

							// 페이스북 계정연동 서비스 종료로 해당영역 DP안함
							/*
							var facebookConnectYn = getFacebookConnectYn();

							if(facebookConnectYn == "" || typeof facebookConnectYn == "undefined"){
								// Cookie에 페이스북 연동 관련 값이 있으면 아래 ajax는 호출하지 않는다.
								try {
									$.ajax({
										url: "https://www.melon.com/gnb/check_connectFacebook.json",
										type : 'GET',
									}).done(function(json) {
										facebookConnectYn = json.facebookConnectYn;

										var facebookConnection = "Y" != facebookConnectYn;
										printFacebookBtn(facebookConnection);
									}).fail(function() {
										printFacebookBtn(true);
									});
								} catch(e){
									printFacebookBtn(true);
								}
							} else {
								var facebookConnection = "Y" != facebookConnectYn;
								printFacebookBtn(facebookConnection);
							}
							*/
						} else {
							html = ['<div class="login_wrap" id="gnbLoginDiv">',
										'<div class="button_login">',
											'<div class="top_area">',
												'<p>멜론을 더 안전하게 이용하세요.</p>',
												'<a href="javascript:MELON.WEBSVC.POC.link.goJoin();" title="회원가입 - 페이지 이동">회원가입</a>',
											'</div>',
											'<button type="button" class="btn_login" onclick="MELON.WEBSVC.POC.login.menuLogin();"><span class="odd_span">로그인</span></button>',
										'</div>',
									'</div>'].join('');
							document.write(html);
						}

						function  printFacebookBtn(facebookConnection){
							var btnHtml = facebookConnection ? '<button type="button" class="btn_info sns_facebook" title="페이스북 연동하기" onclick="goConnectSns();"><span>페이스북 연동하기</span></button>' : '<button type="button" class="btn_info sns_facebook" title="페이스북 해제하기" onclick="goConnectSns();"><span class="cancel">페이스북 해제하기</span></button>';
							$('#d_facebook_mem_btn').html(btnHtml);
						}

						</script>
						<div class="promotion_wrap">
							<!--140701 추가 lyr-->
							<div class="promotion_default">
