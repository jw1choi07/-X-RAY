							<li><a href="//www.melon.com/benefit/lounge/main.htm" title="멜론혜택" class="menu02 mlog" data="LOG_PRT_CODE=1&MENU_PRT_CODE=0&MENU_ID_LV1=&CLICK_AREA_PRT_CODE=V06&ACTION_AF_CLICK=V1"><span>멜론혜택</span></a></li>
							
							<li><a href="/event/list.htm" title="이벤트" class="menu03 mlog" data="LOG_PRT_CODE=1&MENU_PRT_CODE=0&MENU_ID_LV1=&CLICK_AREA_PRT_CODE=B03&ACTION_AF_CLICK=V1"><span>이벤트</span></a></li>
							
							<li class="last_child"><a href="/customer/announce/index.htm" title="공지사항" class="menu04 mlog" data="LOG_PRT_CODE=1&MENU_PRT_CODE=0&MENU_ID_LV1=&CLICK_AREA_PRT_CODE=V02&ACTION_AF_CLICK=V1"><span>공지사항</span></a></li>
						</ul>
						<script type="text/javascript">
							var html = '';
							var logoutReturnUrl = window.location.href;

							if(logoutReturnUrl == ''){
								logoutReturnUrl = 'www.melon.com';
							}

							if(isMelonLogin()){

								var memberKey = getMemberKey()
								var memberInfo = svcMember.displayIdByMemberKey(memberKey);
								var memberType = svcMember.getMemberType().MEMBERTYPE;
								var gradeInfo = svcMember.gradeInfoByMemberKey(memberKey);

								var memId = '';
								if(memberType == undefined || memberType == null){
									memberType = '0';
								}

								if(memberInfo.DISPLAYID != undefined || memberInfo.DISPLAYID != null){
									memId = memberInfo.DISPLAYID;
								}

								if(memId.indexOf("@") != -1 && memberType != '1'){//카카오계정이 아닌경우에만 @도메인 영역 삭제처리
									memId = memId.split("@")[0];
								}

								var fromMPS = getCookie("MPS"); // 멜론 플레이어에서 왔는지 확인.
								var fromMPSYn = fromMPS == null || fromMPS.indexOf("MELONPLAYER") < 0;

								var gradeImg = "";
								var gradeName = gradeInfo.GRADE;

								if(gradeName == undefined || gradeName == null){
									gradeName = '일반';
								}

								try {
									if(gradeName == '일반'){
										gradeImg = "";
									} else if(gradeName == 'GREEN'){
										gradeImg = "<span class=\"icon-comm grade-green\"></span>";
									} else if(gradeName == 'SILVER'){
										gradeImg = "<span class=\"icon-comm grade-silver\"></span>";
									} else if(gradeName == 'GOLD'){
										gradeImg = "<span class=\"icon-comm grade-gold\"></span>";
									} else if(gradeName == 'VIP'){
										gradeImg = "<span class=\"icon-comm grade-vip\"></span>";
									} else if(gradeName == 'MVIP'){
										gradeImg = "<span class=\"icon-comm grade-mvip\"></span>";
									}

									//카카오연동확인
									if(memberType == '1'){
										gradeImg += "<span class=\"icon-comm icon-kakao\"></span>";
									}
								} catch (e) {}

								var logoutButtonHtml = '<button type="button" title="로그아웃" class="btn_top_logout" onclick="javascript:MELON.WEBSVC.POC.logout(\'\');">로그아웃</button>';

								html = ['<div class="header_login">',
									' <span class="icon_grade">',
									'' + gradeImg + '',
									' </span>',
									' <span class="wrap_id"><a href="javascript:location.href=_getHttpsMemberDomain()+ \'/muid/web/help/myinfointro_inform.htm\';" class="user_id"><strong>' + memId + '</strong>님</a></span>',
									fromMPSYn ? logoutButtonHtml : '', //멜론 플레이어에서 로그아웃 싱크 안맞는 이슈로 인해 로그아웃 멜론 플레이어에서 왔을 시 버튼 제거
									'</div>'
								].join('');
								document.write(html);
							}
						</script>
					</div>
					<!-- //140603_수정 -->
				</div>
				<!-- //상단 빠른 메뉴 -->

				<div class="header-utils">
