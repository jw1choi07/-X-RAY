	<span class="shadow"></span>
</div>
<!-- //MELONUIT-1148 20200121 ISMS 인증서 팝업 -->

		<script type="text/javascript">
			$(function() {
				//favicon 분기 처리
				var pocId = MELON.WEBSVC.POC.getPocId();
				if('AS20' == pocId || 'HT10' == pocId){
					$('link#favicon').attr('href','//cdnimg.melon.co.kr/resource/mobile40/cds/common/image/favicon.ico');
					$('title').text('Melon');
				}else if('IS20' == pocId || 'IT10' == pocId){
					$('link#favicon').attr('type','');
					$('link#favicon').attr('rel','apple-touch-icon-precomposed');
					$('link#favicon').attr('href','//cdnimg.melon.co.kr/resource/mobile40/cds/common/image/mobile_apple_120x120.png');
					$('link#favicon').after('<link rel="apple-touch-icon-precomposed" sizes="180x180" href="//cdnimg.melon.co.kr/resource/mobile40/cds/common/image/mobile_apple_180x180.png" />');
					$('title').text('Melon');
				}

				// 엣지 브라우저이고 해당 팝업이 뜬 적이 없는 경우 체크하여 팝업을 띄운다.
				var isEdge = (navigator.userAgent.indexOf("Edge") > 0);
				var edgeCheckYN = getCookie("EDGE_CHECK") != 'Y';


				// 타블렛이고 해당 팝업이 뜬 적이 없는 경우 체크하여 팝업을 띄운다.
				var tabletCheckYN = getCookie("TABLET_CHECK") != 'Y';

				if(melon.isTablet() && tabletCheckYN){
					window.open('//www.melon.com/error_page/error_tabletTypeA.html','tabletPopTypeA','scrollbars=no, resizable=no, location=no, width=560, height=483');
				}

				// 해당 쿠키가 존재하면 쿠키 삭제
				if(getCookie("CHECK_POP") != ''){
					// 체크 후 해당 쿠키는 제거
					var expireDate = new Date();
					expireDate.setDate(expireDate.getDate()-1);
					document.cookie = "CHECK_POP=;path=/;expires="+expireDate.toGMTString()+";domain=.melon.com";
				}

				if(isMelonLogin()){
					var djYn = false;
					var memberKey = getMemberKey();


					if(memberKey != null || memberKey != ''){
						var url = '/dj/members/'+memberKey+'/isdj.json';
						var promotionPopup = window.localStorage.getItem('promotionpopup'+getMemberKey());

						try {
							$.ajax({
								url: url,
								type : 'GET',
								dataType: 'json'
							}).done(function(data) {
								if (data != null && data.ISDJ != null && data.ISDJ.length > 0) {
									djYn = data.ISDJ;
								}
							}).fail(function() {
								djYn = false;
							});


							if(promotionPopup == null && isLoginWithin20Seconds()){
								var fromMPS = getCookie("MPS"); // 멜론 플레이어에서 왔는지 확인.

								// PCP이면 찌르지 않음
								if(POC_ID != 'VP40' && fromMPS.indexOf("MELONPLAYER") < 0) {
									$.ajax({
										url: '/commapi/v1/loginPromotion.json',
										type : 'GET',
										dataType: 'json',
										data : {memberKey : memberKey,
											pocId : getCookie("POC")}
									}).done(function(data) {
										if (data != undefined && data != null && data.PROMOTIONINFO != null && data.PROMOTIONINFO.PROMOTARGETMAP != null) {
											if(data.PROMOTIONINFO.PROMOTARGETMAP.promoLinkUrl != null){
												var promotionLinkUrl = data.PROMOTIONINFO.PROMOTARGETMAP.promoLinkUrl;

												try {
													var urlObj = new URL(promotionLinkUrl);
													var params = new URLSearchParams(urlObj.search);
												} catch (e) {
													var params = new URLSearchParams();
												}

												var width = params.get("width")  != null ? params.get("width") : '560';
												var height = params.get("height") != null ? params.get("height") : '780';
												var inflowCode = params.get("inflowCode") != null ? params.get("inflowCode") : '';
												var loginPromoId = params.get("loginPromoId") != null ? params.get("loginPromoId") : '';

												//inflowCode값이 IC0017가 아니거나, 해당 쿠키값이 존재하지 않을 떄 팝업 호출
												if (inflowCode != "IC0017" || getCookie('block_'+getMemberKey()+'_'+loginPromoId) == '') {
													window.open(promotionLinkUrl, '', 'width='+width+', height='+height+', left=50, top=100');
												}

												window.localStorage.setItem('promotionpopup'+getMemberKey(), '1');
											}
										}
									}).fail(function() {
										console.log('promotionPopup AJAX Failed!!!');
										window.localStorage.removeItem('promotionpopup'+getMemberKey());
									});
								}
							}

						} catch(e){}
					}
				}

				// 홈탭의 경우 쇼핑/티켓을 새창띄우기로 변경한다.
				var fromMPS = getCookie("MPS"); // 멜론 플레이어에서 왔는지 확인.
				var fromHomeTab = !(fromMPS == null || fromMPS.indexOf("MELONPLAYER") < 0);

				if(fromHomeTab){
					$("li.d_melon_shopping a").removeClass("mlog");
					$("li.d_melon_shopping a").addClass("mlog_without_page_change");
					$("li.d_melon_shopping a").attr("target", "_blank");

					$("li.d_melon_ticket a").removeClass("mlog");
					$("li.d_melon_ticket a").addClass("mlog_without_page_change");
					$("li.d_melon_ticket a").attr("target", "_blank");
				}

				//멜론 플레이어면 멜론 6.0 둘러보기 버튼 제거
				if(fromHomeTab){
					$('#d_studio').hide()
					$('#d_melon6').hide();
				}else{
					$('#d_studio').show()
					$('#d_melon6').show();
				}

				$(document).on('limitpopup', function( e, cookieId ) {
					$('#'+cookieId).modal();
				});


				//레이어 공지 제어
				//메인만 적용
				//pcp 홈탭 미적용
				if('10010101' == '10010101' && !fromHomeTab){
					$.ajax({
						type : 'GET'
						,url : '/main/getTicketPositionProperty.json'
					}).done(function(response) {

						var layerPopNotiYn = response.layerPopNotiYn;
						var layerPopDateText = response.layerPopDateText;
						if(layerPopNotiYn == 'Y'){
							$('#d_layerPopDateText').text(layerPopDateText);
							setTimeout(function() {
								$("#popNotice").timeLimitSet({ cookieId:'popNotice',selectors:{closebtn:'#todayChk', checkbox:''} });
							},1);
							MELON.PBPGN.TimeLimitPopup.init({ cookieId:"popNotice", serverTime: new Date(), limitType:"day" });
							$("#popNotice .d_close").click(function() {  $("#popNotice").modal('hide'); });
						}
					});
				}
			});

			function goMelonTPage(){
				//t.com 종료 삭제처리
			}

			function isLoginWithin20Seconds() {
				const now = new Date();
				const loginTime = parseLoginTime(getLoginTime());
				const timeDifference = Math.abs(now - loginTime) / 1000;
				return timeDifference <= 20;
			}

			function parseLoginTime(loginTimeStr) {
				const year = parseInt(loginTimeStr.substring(0, 4), 10);
				const month = parseInt(loginTimeStr.substring(4, 6), 10) - 1;
				const day = parseInt(loginTimeStr.substring(6, 8), 10);
				const hours = parseInt(loginTimeStr.substring(8, 10), 10);
				const minutes = parseInt(loginTimeStr.substring(10, 12), 10);
				const seconds = parseInt(loginTimeStr.substring(12, 14), 10);

				return new Date(year, month, day, hours, minutes, seconds);
			}

			function openEmailCollectionReject(){
				window.open('//www.melon.com/emailCollectionReject.html','emailCollect', 'scrollbars=no, resizable=no, location=no, width=384, height=331');
			}

			//MELONUIT-1148 20200121 ISMS 인증서 팝업 //
			var popISMS = {
				open : function() {
					$('#pop_isms').modal('show');
				}
			};

			$(document).on('click', '.popISMS',function(){
				popISMS.open();
			});
			//MELONUIT-1148 20200121 ISMS 인증서 팝업 //
		</script>
		<!--//140602 추가 lyr-->

	</div>
	<!-- //footer -->
</div>

