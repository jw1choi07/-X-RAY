<!doctype html><html lang="ko"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><script>(function () {
        try {
          var MOBILE_URL = 'https://m.munpia.com';
          var pathname = window.location.pathname.replace(/\/+$/, '');
          // 파셜 프리뷰 경로 제외 (gtag 인라인 스크립트와 동일 가드)
          if (pathname === '/common/parts') return;
          // 치환 실패/미설정 방어 (http(s) URL이 아니면 종료)
          if (!/^https?:\/\//.test(MOBILE_URL)) return;
          // 'PC 버전으로 보기'로 심긴 쿠키가 있으면 PC 유지
          if (/(?:^|; )mobileview=true(?:;|$)/.test(document.cookie)) return;
          // 검색 봇 제외: Googlebot 스마트폰 등은 UA에 Android가 있어 아래 모바일 판정에 걸린다.
          // 봇까지 모바일로 보내면 데스크톱 하위 페이지가 전부 모바일 홈으로 튕겨 Google의
          // 'faulty redirect'(색인 누락)로 취급되므로, 봇은 데스크톱을 그대로 크롤하게 둔다.
          if (/bot|crawl|spider|slurp|mediapartners|Yeti|Daum/i.test(navigator.userAgent)) return;
          // 모바일 기기(UA)가 아니면 유지 (useIsMobile 훅과 동일 정규식)
          if (!/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) return;
          // 모바일 기기 + 쿠키 없음 → 모바일 사이트로 (뒤로가기 루프 방지 위해 replace)
          window.location.replace(MOBILE_URL);
        } catch (e) {}
      })();</script><meta name="theme-color" content="#FFFFFF"/><meta name="description" content="무료웹소설 최다 보유! 무협, 판타지, 인기 웹소설 연재 플랫폼, 무료 웹소설 아카데미 운영"/><meta name="keywords" content="글세상 문피아,Munpia,장르소설,웹소설,연재,창작,만화,웹툰,게임,음악,판타지,무협,로맨스,19금,BL,플래티넘,베스트,서재"/><meta property="og:title" content="웹소설 문피아"/><meta property="og:description" content="무료웹소설 최다 보유! 무협, 판타지, 인기 웹소설 연재 플랫폼, 무료 웹소설 아카데미 운영"/><meta property="og:image" content="https://cdn2.munpia.com/asset/img/pic@app144.png"/><meta property="og:type" content="website"/><meta property="og:url" content="https://www.munpia.com"/><meta property="og:site_name" content="문피아"/><meta property="og:locale" content="ko_KR"/><meta name="twitter:card" content="summary_large_image"/><meta name="twitter:title" content="웹소설의 유토피아, 글세상 문피아"/><meta name="twitter:description" content="무료웹소설 최다 보유! 무협, 판타지, 인기 웹소설 연재 플랫폼, 무료 웹소설 아카데미 운영"/><meta name="twitter:image" content="https://cdn2.munpia.com/asset/img/pic@app144.png"/><link rel="shortcut icon" href="https://cdn1.munpia.com/favicon.ico"/><link rel="icon" href="https://cdn2.munpia.com/asset/img/android-icon-192.png" sizes="192x192"/><link rel="apple-touch-icon-precomposed" sizes="192x192" href="https://cdn2.munpia.com/asset/img/android-icon-192.png"/><link rel="canonical" href="https://www.munpia.com"/><link rel="alternate" media="only screen and (max-width: 640px)" href="https://m.munpia.com"/><title>웹소설의 유토피아, 글세상 문피아</title><script>(function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'light' || t === 'dark') {
            document.documentElement.setAttribute('data-theme', t);
          } else {
            var c = document.cookie.match(/(?:^|; )thememode=([^;]*)/);
            if (c && (c[1] === 'light' || c[1] === 'dark')) {
              document.documentElement.setAttribute('data-theme', c[1]);
            } else {
              document.documentElement.setAttribute('data-theme', 'light');
            }
          }
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();</script><script>(function () {
        try {
          var p = window.location.pathname.replace(/\/+$/, '');
          if (p !== '' && p !== '/search') return;
          var prefer = /[?&]mode=prefer(?:&|$)/.test(window.location.search);
          var m = document.cookie.match(/(?:^|; )mp_sidesearch_drawer=([^;]*)/);
          var open = prefer || (m && m[1] === 'true');
          document.documentElement.setAttribute('data-side-search-open', open ? 'true' : 'false');
